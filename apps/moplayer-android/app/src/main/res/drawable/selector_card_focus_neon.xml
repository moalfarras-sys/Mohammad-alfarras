<?xml version="1.0" encoding="utf-8"?>
<!-- Content card selector with Neon Cyan focus glow — replaces selector_card_focus -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1100F0FF" />
                    <corners android:radius="22dp" />
                </shape>
            </item>
            <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <stroke android:width="1.5dp" android:color="#99FFFFFF" />
                    <solid android:color="#1A00F0FF" />
                    <corners android:radius="20dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#2A00F0FF" />
            <corners android:radius="22dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#111111" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</selector>
