<?xml version="1.0" encoding="utf-8"?>
<!-- Watch Progress Bar Background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background Track -->
    <item android:id="@android:id/background">
        <shape android:shape="rectangle">
            <solid android:color="@color/htc_progress_background"/>
            <corners android:radius="@dimen/progress_corner_radius"/>
        </shape>
    </item>
    
    <!-- Progress Bar -->
    <item android:id="@android:id/progress">
        <clip>
            <shape android:shape="rectangle">
                <solid android:color="@color/htc_progress_primary"/>
                <corners android:radius="@dimen/progress_corner_radius"/>
            </shape>
        </clip>
    </item>
</layer-list>
