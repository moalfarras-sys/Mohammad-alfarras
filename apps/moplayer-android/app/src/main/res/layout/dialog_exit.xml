<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D1020510">

    <LinearLayout
        android:layout_width="420dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_panel_premium"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="34dp"
        android:paddingTop="28dp"
        android:paddingBottom="26dp">

        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <View
                android:id="@+id/logoGlow"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:alpha="0.48"
                android:background="@drawable/bg_exit_logo_glow" />

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/moplayer_brand_logo_new"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="sans-serif-medium"
            android:text="@string/exit_title"
            android:textColor="@color/htc_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="@string/exit_message"
            android:textColor="@color/htc_text_secondary"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnStay"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/selector_glass_button"
                android:focusable="true"
                android:text="@string/exit_cancel"
                android:textAllCaps="false"
                android:textColor="@color/htc_text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnExit"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_danger"
                android:focusable="true"
                android:text="@string/exit_confirm"
                android:textAllCaps="false"
                android:textColor="@color/htc_pure_white"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
