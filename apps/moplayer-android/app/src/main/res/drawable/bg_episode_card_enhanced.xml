<?xml version="1.0" encoding="utf-8"?>
<!-- Episode Card Enhanced Background — premium glass effect -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Base card surface -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="315"
                android:startColor="#260D2240"
                android:centerColor="#200A1A30"
                android:endColor="#1C06121E" />
        </shape>
    </item>

    <!-- Top highlight shimmer -->
    <item android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.1"
                android:centerY="0.0"
                android:startColor="#1400F5FF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="#285B7CFF" />
        </shape>
    </item>

</layer-list>
