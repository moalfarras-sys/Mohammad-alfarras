<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer gradient glow -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="160dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#4000FF88"
                android:centerColor="#2000AAFF"
                android:endColor="#00000000" />
            <size android:width="320dp" android:height="320dp" />
        </shape>
    </item>
    
    <!-- Glass circle -->
    <item android:left="30dp" android:top="30dp" android:right="30dp" android:bottom="30dp">
        <shape android:shape="oval">
            <!-- Frosted glass -->
            <solid android:color="#40101014" />
            <stroke
                android:width="2dp"
                android:color="#60FFFFFF" />
        </shape>
    </item>
    
    <!-- Inner glass border -->
    <item android:left="32dp" android:top="32dp" android:right="32dp" android:bottom="32dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#3000FF88" />
        </shape>
    </item>
</layer-list>
