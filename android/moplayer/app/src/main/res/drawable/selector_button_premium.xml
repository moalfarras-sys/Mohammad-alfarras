<?xml version="1.0" encoding="utf-8"?>
<!-- Button Focus selector with premium styling -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state with gold gradient -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Glow effect -->
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="315"
                        android:endColor="@color/gradient_gold_end"
                        android:startColor="@color/gradient_gold_start"
                        android:type="linear" />
                    <corners android:radius="12dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="@color/gradient_gold_dark"
                android:startColor="@color/gradient_gold_mid"
                android:type="linear" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/htc_surface" />
            <corners android:radius="12dp" />
            <stroke android:width="1dp" android:color="@color/htc_card_border" />
        </shape>
    </item>
    
</selector>
