<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <item
        android:left="-4dp"
        android:top="-4dp"
        android:right="-4dp"
        android:bottom="-4dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="100dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="@color/liquid_accent_primary_soft"
                        android:endColor="#00000000" />
                </shape>
            </item>
    
    <!-- Shadow layer 1 (outer, softer) -->
    <item
        android:left="0dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#30000000" />
        </shape>
    </item>
    
    <!-- Shadow layer 2 (closer, darker) -->
    <item
        android:left="0dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#40000000" />
        </shape>
    </item>
    
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <gradient
                android:angle="315"
                android:startColor="@color/liquid_glass_surface_strong"
                android:centerColor="@color/liquid_glass_surface"
                android:endColor="#0F1523"
                android:type="linear" />
        </shape>
    </item>
    
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <stroke
                android:width="1.5dp"
                android:color="@color/liquid_glass_border" />
        </shape>
    </item>
    
    <item
        android:left="12dp"
        android:top="1dp"
        android:right="12dp">
        <shape android:shape="rectangle">
            <size android:height="1dp" />
            <gradient
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="@color/liquid_glass_highlight"
                android:endColor="#00FFFFFF"
                android:type="linear" />
        </shape>
    </item>
    
</layer-list>
