<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient android:angle="315" android:startColor="#37D5FF" android:endColor="#7257FF" />
            <stroke android:width="2dp" android:color="#DDF9FFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient android:angle="315" android:startColor="#1C8CF2FF" android:endColor="#264F46FF" />
            <stroke android:width="1dp" android:color="#655DEBFF" />
        </shape>
    </item>
</selector>
