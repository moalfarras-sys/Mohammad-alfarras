<?xml version="1.0" encoding="utf-8"?>
<!-- Liquid focus glow — vivid cyan radial for strong TV focus indication -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Primary cyan glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/cinematic_radius_card" />
            <gradient
                android:type="radial"
                android:centerX="50%"
                android:centerY="50%"
                android:gradientRadius="280dp"
                android:startColor="#5815C4D2"
                android:centerColor="#2415C4D2"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

    <!-- Cyan depth accent glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/cinematic_radius_card" />
            <gradient
                android:type="radial"
                android:centerX="50%"
                android:centerY="65%"
                android:gradientRadius="180dp"
                android:startColor="#2415C4D2"
                android:endColor="@android:color/transparent" />
        </shape>
    </item>

</layer-list>
