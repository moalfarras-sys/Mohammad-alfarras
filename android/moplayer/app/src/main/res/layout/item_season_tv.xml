<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:layout_marginHorizontal="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="@drawable/selector_cinematic_card">

    <androidx.cardview.widget.CardView
        android:id="@+id/seasonCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:background="@drawable/bg_season_card_tv"
        android:clickable="false"
        android:focusable="false">

        <LinearLayout
            android:id="@+id/seasonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_season_card_tv"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="12dp"
            android:paddingHorizontal="8dp">

            <!-- Season Number Badge -->
            <FrameLayout
                android:layout_width="@dimen/tv_season_badge_size"
                android:layout_height="@dimen/tv_season_badge_size">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_season_number" />

                <TextView
                    android:id="@+id/tvSeasonNumber"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="@color/htc_text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    tools:text="1" />

            </FrameLayout>

            <!-- Season Label -->
            <TextView
                android:id="@+id/tvSeasonLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="1"
                android:textColor="@color/htc_text_secondary"
                android:textSize="11sp"
                android:textStyle="bold"
                tools:text="Season 1" />

            <!-- Episode Count -->
            <TextView
                android:id="@+id/tvEpisodeCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/htc_text_tertiary"
                android:textSize="10sp"
                tools:text="10 eps" />

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Selection Indicator -->
    <View
        android:id="@+id/selectionIndicator"
        android:layout_width="4dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/htc_accent_green"
        android:visibility="gone" />

    <!-- Focus Glow -->
    <View
        android:id="@+id/focusGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_cinematic_focus_glow"
        android:visibility="invisible" />

</FrameLayout>
