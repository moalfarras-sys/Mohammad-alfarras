<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="80dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#404F8BFF"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:angle="45"
                        android:startColor="@color/moplayer_orange"
                        android:endColor="@color/moplayer_orange_light"
                        android:type="linear" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/moplayer_orange_dark" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="45"
                android:startColor="@color/moplayer_orange"
                android:endColor="@color/moplayer_orange_dark"
                android:type="linear" />
        </shape>
    </item>
</selector>
