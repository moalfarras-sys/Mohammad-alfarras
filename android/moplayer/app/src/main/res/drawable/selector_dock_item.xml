<?xml version="1.0" encoding="utf-8"?>
<!-- Luxury Gold Dock Item Selector -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state - Gold glow -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Gold glow background -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="60dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="@color/glow_gold_medium"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <!-- Gold border -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/focus_gold_bright" />
                    <solid android:color="#00000000" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Selected state - Subtle gold -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/glow_gold_very_subtle" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

</selector>
