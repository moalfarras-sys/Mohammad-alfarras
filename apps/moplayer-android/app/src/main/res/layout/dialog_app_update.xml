<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="520dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_premium"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/tvUpdateEyebrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_quality_badge_premium"
        android:fontFamily="sans-serif-medium"
        android:paddingHorizontal="12dp"
        android:paddingVertical="5dp"
        android:text="@string/update_available_eyebrow"
        android:textColor="@color/moplayer_orange_light"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvUpdateTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingExtra="2dp"
        android:textColor="@color/cinematic_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        tools:text="Update available - 2.2.7" />

    <TextView
        android:id="@+id/tvUpdateVersion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/moplayer_orange_light"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="Installed 12 - Latest 13" />

    <TextView
        android:id="@+id/tvUpdateMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:lineSpacingExtra="3dp"
        android:maxLines="6"
        android:textColor="@color/cinematic_text_secondary"
        android:textSize="14sp"
        tools:text="MoPlayer Classic update improves Settings, backgrounds, and playback stability." />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="end|center_vertical"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnUpdateLater"
            android:layout_width="132dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_button_secondary"
            android:focusable="true"
            android:nextFocusRight="@id/btnUpdateNow"
            android:text="@string/update_later"
            android:textAllCaps="false"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnUpdateNow"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_button_play"
            android:focusable="true"
            android:nextFocusLeft="@id/btnUpdateLater"
            android:text="@string/update_now"
            android:textAllCaps="false"
            android:textColor="@color/htc_pure_black"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
