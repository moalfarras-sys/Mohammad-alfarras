<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-2dp"
                android:top="-2dp"
                android:right="-2dp"
                android:bottom="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <gradient
                        android:type="radial"
                    android:gradientRadius="140dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#AA00E5FF"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:angle="135"
                        android:startColor="#AA00E5FF"
                        android:centerColor="#66286DFF"
                        android:endColor="#997C3AED" />
                    <stroke android:width="2.5dp" android:color="#FFFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/liquid_glass_surface_strong" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="#55204878"
                android:centerColor="#3313244F"
                android:endColor="#441B1038" />
            <stroke android:width="1.2dp" android:color="#55B9F7FF" />
        </shape>
    </item>
</selector>
