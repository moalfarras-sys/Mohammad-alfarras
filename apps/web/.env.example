###############################################################################
# moalfarras.space — public env template
# Copy to .env.local and fill in real values. Never commit real secrets.
###############################################################################

# --- Admin (control center auth) -------------------------------------------
# Comma-separated allowlist of admin emails (lower-cased server-side).
ADMIN_ALLOWLIST="you@example.com"
ADMIN_EMAIL="you@example.com"

# Generate via:  node scripts/hash-admin-password.mjs "<your password>"
ADMIN_PASSWORD_HASH="scrypt$<salt>$<derived>"

# 48+ random bytes (hex). Generate via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."

# Optional Expo / Android client mirrors
EXPO_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
EXPO_PUBLIC_SUPABASE_KEY="sb_publishable_..."

# Server-only (do NOT prefix with NEXT_PUBLIC_)
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# --- Public site / app URLs -----------------------------------------------
NEXT_PUBLIC_WEB_APP_URL="https://moalfarras.space"
NEXT_PUBLIC_ADMIN_APP_URL="https://admin.moalfarras.space"

# --- Live data integrations (optional) -------------------------------------
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""
WEATHER_API_KEY=""
API_FOOTBALL_KEY=""
RAPIDAPI_FOOTBALL_KEY=""

# --- Contact email delivery (optional, server-only) ------------------------
# If these are unset, the contact API falls back to DATABASE_URL/DIRECT_URL.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Mohammad Alfarras <contact@moalfarras.space>"
CONTACT_TO_EMAIL="mohammad.alfarras@gmail.com"

# --- Vercel ---------------------------------------------------------------
EDGE_CONFIG=""

# --- SEO ------------------------------------------------------------------
GOOGLE_SITE_VERIFICATION=""
