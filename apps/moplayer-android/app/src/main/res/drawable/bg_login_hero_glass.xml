<?xml version="1.0" encoding="utf-8"?>
<!-- Premium obsidian glass card for login -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep background with cyan/violet obsidian feel -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:angle="315"
                android:startColor="#E6020510"
                android:centerColor="#EA03071A"
                android:endColor="#DE040A28" />
            <stroke android:width="1dp" android:color="#3300F5FF" />
        </shape>
    </item>

    <!-- Top highlight for glass effect -->
    <item android:bottom="80dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="24dp" android:topRightRadius="24dp" />
            <gradient android:angle="270"
                android:startColor="#1500F5FF"
                android:endColor="#00000000" />
        </shape>
    </item>
    
    <!-- Outer fine glow border -->
    <item android:left="1dp" android:top="1dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
