###############################################################################
# moalfarras.space — public env template
# Copy to .env.local and fill in real values. Never commit real secrets.
###############################################################################

# --- Admin (control center auth) -------------------------------------------
# Comma-separated allowlist of admin emails (lower-cased server-side).
ADMIN_ALLOWLIST="mohammad.alfarras@gmail.com"
ADMIN_EMAIL="mohammad.alfarras@gmail.com"

# Generate via:  node scripts/hash-admin-password.mjs "<your password>"
ADMIN_PASSWORD_HASH="scrypt$<salt>$<derived>"

# 48+ random bytes (hex). Generate via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# --- Supabase --------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="sb_publishable_..."

# Optional Expo / Android client mirrors
EXPO_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
EXPO_PUBLIC_SUPABASE_KEY="sb_publishable_..."

# Server-only (do NOT prefix with NEXT_PUBLIC_)
DATABASE_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require"
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Server-only key used to encrypt website-delivered Xtream/M3U source payloads
# before they are stored in Supabase. Use a stable 32+ byte random value in
# production. If omitted locally, the service-role key is used as fallback.
MOPLAYER_PROVIDER_ENCRYPTION_KEY="<32+ byte random server-only key>"

# Optional Supabase Storage S3-compatible endpoint used by release tooling.
SUPABASE_PROJECT_REF="<project-ref>"
SUPABASE_STORAGE_S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
SUPABASE_STORAGE_S3_ACCESS_KEY_ID="<storage-access-key-id>"
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY="<storage-secret-access-key>"

# Optional SMTP metadata for local tooling/documentation. Supabase Auth SMTP is
# configured from the Supabase dashboard, not read by the Next.js apps directly.
SMTP_HOST=""
SMTP_PORT="465"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_EMAIL=""

# --- Public site / app URLs -----------------------------------------------
NEXT_PUBLIC_WEB_APP_URL="https://moalfarras.space"
NEXT_PUBLIC_ADMIN_APP_URL="https://admin.moalfarras.space"

# --- Live data integrations (optional) -------------------------------------
WEATHER_API_KEY="<weather-api-key>"
YOUTUBE_API_KEY="<youtube-api-key>"
YOUTUBE_CHANNEL_ID="UCfQKyFnNaW026LVb5TGx87g"
API_FOOTBALL_KEY="<api-football-key>"
RAPIDAPI_FOOTBALL_KEY="<rapidapi-football-key>"
