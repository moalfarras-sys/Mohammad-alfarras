<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dateContainer"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/selector_glass_button"
    android:focusable="true"
    android:gravity="center"
    android:minWidth="80dp"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingVertical="12dp"
    android:layout_marginEnd="8dp">

    <TextView
        android:id="@+id/tvDayName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/htc_text_secondary"
        android:textSize="12sp"
        tools:text="Mon" />

    <TextView
        android:id="@+id/tvDayNumber"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/htc_text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="15" />

    <TextView
        android:id="@+id/tvMonth"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/htc_text_tertiary"
        android:textSize="11sp"
        tools:text="Jan" />

</LinearLayout>
