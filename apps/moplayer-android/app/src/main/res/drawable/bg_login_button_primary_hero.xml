<?xml version="1.0" encoding="utf-8"?>
<!-- Primary hero button: Vivid cyan pill -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item android:left="-4dp" android:top="-4dp" android:right="-4dp" android:bottom="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="18dp" />
                    <gradient android:type="radial" android:gradientRadius="160dp"
                        android:centerX="0.5" android:centerY="0.5"
                        android:startColor="#665B7CFF" android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient android:angle="0"
                        android:startColor="@color/cinematic_cyan"
                        android:endColor="@color/cinematic_cyan_light" />
                    <stroke android:width="2dp" android:color="#AAFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/cinematic_cyan_dark" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient android:angle="0"
                android:startColor="@color/cinematic_cyan_dark"
                android:endColor="@color/cinematic_cyan" />
            <stroke android:width="1dp" android:color="#40FFFFFF" />
        </shape>
    </item>
</selector>
