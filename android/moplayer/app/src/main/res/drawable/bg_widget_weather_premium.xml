<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer ambient glow — cyan/blue tint -->
    <item android:left="-3dp" android:top="-3dp" android:right="-3dp" android:bottom="-3dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="200dp"
                android:centerX="0.3"
                android:centerY="0.5"
                android:startColor="#1006B6D4"
                android:centerColor="#0806B6D4"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Main glass surface -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="155"
                android:startColor="#D00D1220"
                android:centerColor="#C00B1018"
                android:endColor="#B80B0F1A" />
            <stroke
                android:width="1dp"
                android:color="#20FFFFFF" />
        </shape>
    </item>

    <!-- Top highlight shimmer -->
    <item android:top="1dp" android:left="16dp" android:right="16dp">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#1406B6D4"
                android:endColor="#00FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>

    <!-- Inner subtle reflection -->
    <item android:top="2dp" android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="270"
                android:startColor="#06FFFFFF"
                android:endColor="#00000000" />
            <size android:height="18dp" />
        </shape>
    </item>

</layer-list>
