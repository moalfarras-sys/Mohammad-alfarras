<?xml version="1.0" encoding="utf-8"?>
<!-- HTC TouchFLO 3D Style Curved Dock Background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Main curved gradient background -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#00000000"
                android:centerColor="#CC000000"
                android:endColor="#F0000000" />
        </shape>
    </item>

    <!-- Top curved edge highlight -->
    <item android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#40FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Glass reflection at top -->
    <item android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="30dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#15FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>

    <!-- Bottom accent line -->
    <item android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:height="1dp" />
            <solid android:color="#20FFFFFF" />
        </shape>
    </item>

</layer-list>
