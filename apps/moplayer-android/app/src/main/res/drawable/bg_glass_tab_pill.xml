<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Tab Pill - Solid Minimal Design -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Selected state - Blue gradient -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/htc_accent_green"
                android:endColor="@color/htc_accent_green_dark" />
        </shape>
    </item>
    
    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/htc_light_gray" />
            <stroke
                android:width="2dp"
                android:color="@color/htc_accent_green" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <solid android:color="@color/htc_dark_gray" />
            <stroke
                android:width="1dp"
                android:color="@color/htc_silver" />
        </shape>
    </item>
    
</selector>
