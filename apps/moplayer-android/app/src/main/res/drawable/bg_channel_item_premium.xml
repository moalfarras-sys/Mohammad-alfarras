<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused state -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:type="linear"
                        android:angle="135"
                        android:startColor="#F00B3A50"
                        android:endColor="#F0102342" />
                    <stroke
                        android:width="2dp"
                        android:color="#FF72E7F2" />
                </shape>
            </item>
            <!-- Glass shine -->
            <item android:top="0dp" android:left="4dp" android:right="4dp">
                <shape android:shape="rectangle">
                    <corners android:topLeftRadius="12dp" android:topRightRadius="12dp" />
                    <gradient
                        android:type="linear"
                        android:angle="270"
                        android:startColor="#246FF7FF"
                        android:endColor="#006FF7FF"
                        android:centerY="0.3" />
                    <size android:height="20dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Selected/Playing state -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#25FFFFFF"
                android:endColor="#15FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="@color/glow_gold_medium" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#18FFFFFF"
                android:endColor="#08FFFFFF" />
            <stroke
                android:width="1dp"
                android:color="#15FFFFFF" />
        </shape>
    </item>
</selector>
