<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000">

    <LinearLayout
        android:layout_width="380dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog_premium"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingTop="32dp"
        android:paddingBottom="28dp">

        <!-- Logo with Glow -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <!-- Glow (sized to match the 80dp icon) -->
            <View
                android:id="@+id/logoGlow"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:alpha="0.6"
                android:background="@drawable/bg_logo_glow_outer" />

            <!-- Logo Mark (160dp wide to show text clearly) -->
            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="160dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/logo"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/exit_title"
            android:textColor="@color/htc_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Message -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="@string/exit_message"
            android:textColor="@color/htc_text_secondary"
            android:textSize="14sp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <!-- Stay Button -->
            <Button
                android:id="@+id/btnStay"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_play"
                android:focusable="true"
                android:text="@string/exit_cancel"
                android:textAllCaps="false"
                android:textColor="@color/htc_pure_black"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- Exit Button -->
            <Button
                android:id="@+id/btnExit"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_exit"
                android:focusable="true"
                android:text="@string/exit_confirm"
                android:textAllCaps="false"
                android:textColor="@color/htc_pure_white"
                android:textSize="14sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
