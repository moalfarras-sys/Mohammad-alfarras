<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ExoPlayer SurfaceView (primary engine) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/exoPlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:use_controller="false"
        app:surface_type="surface_view" />

    <!-- VLC Video Layout (fallback engine) -->
    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlcVideoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <View
        android:id="@+id/topScrim"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_gravity="top"
        android:background="@drawable/bg_player_top_gradient"
        android:visibility="gone"
        tools:visibility="visible" />

    <View
        android:id="@+id/bottomScrim"
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_bottom_gradient"
        android:visibility="gone"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/topControlsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/selector_tv_button"
            android:contentDescription="@string/cd_back"
            android:padding="14dp"
            android:src="@drawable/ic_back"
            app:tint="@color/cinematic_text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="18dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="MoPlayer Premium Stream" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cinematic_text_secondary"
                    android:textSize="13sp"
                    tools:text="Live TV" />

                <TextView
                    android:id="@+id/liveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:background="@drawable/bg_live_badge"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="LIVE"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvPlaybackMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:textColor="@color/cinematic_text_tertiary"
                    android:textSize="12sp"
                    tools:text="Premier League • 67'" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="21:36" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/centerControls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageButton
            android:id="@+id/btnPreviousChannel"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/selector_tv_button"
            android:padding="16dp"
            android:src="@drawable/ic_skip_previous"
            app:tint="@color/cinematic_text_primary" />

        <ImageButton
            android:id="@+id/btnRewind"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/selector_tv_button"
            android:padding="18dp"
            android:src="@drawable/ic_rewind"
            app:tint="@color/cinematic_text_primary" />

        <ImageButton
            android:id="@+id/btnPlayPause"
            android:layout_width="86dp"
            android:layout_height="86dp"
            android:layout_marginHorizontal="14dp"
            android:background="@drawable/bg_button_play"
            android:padding="22dp"
            android:src="@drawable/ic_pause"
            app:tint="@color/htc_pure_black" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/selector_tv_button"
            android:padding="18dp"
            android:src="@drawable/ic_forward"
            app:tint="@color/cinematic_text_primary" />

        <ImageButton
            android:id="@+id/btnNextChannel"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/selector_tv_button"
            android:padding="16dp"
            android:src="@drawable/ic_skip_next"
            app:tint="@color/cinematic_text_primary" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottomControlsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="22dp"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cinematic_text_secondary"
                android:textSize="13sp"
                tools:text="00:14" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="35"
                android:progressDrawable="@drawable/bg_progress_bar"
                android:thumb="@drawable/bg_seekbar_thumb" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/cinematic_text_secondary"
                android:textSize="13sp"
                tools:text="02:20" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnGuide"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:background="@drawable/selector_tv_button"
                android:padding="14dp"
                android:src="@drawable/ic_live_tv"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnAudio"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_tv_button"
                android:padding="14dp"
                android:src="@drawable/ic_audio"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnSubtitles"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_tv_button"
                android:padding="14dp"
                android:src="@drawable/ic_subtitles"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnAspectRatio"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_tv_button"
                android:padding="14dp"
                android:src="@drawable/ic_aspect_ratio"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnSpeed"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_tv_button"
                android:padding="14dp"
                android:src="@drawable/ic_speed"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnExternalPlayer"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/selector_tv_button"
                android:padding="14dp"
                android:src="@drawable/ic_external"
                app:tint="@color/cinematic_text_primary" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/optionSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="380dp"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="24dp"
            android:background="@drawable/bg_glass_panel_premium"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:id="@+id/tvOptionSheetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="Audio Tracks" />

            <LinearLayout
                android:id="@+id/optionSheetContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/channelDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#52000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="420dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_dialog_premium"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_quick_guide"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="15sp"
                tools:text="Now • Main Event Coverage" />

            <TextView
                android:id="@+id/tvNextProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/cinematic_text_secondary"
                android:textSize="13sp"
                tools:text="Next • Studio Analysis" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:id="@+id/channelListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <Button
        android:id="@+id/btnSkipIntro"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="140dp"
        android:background="@drawable/bg_button_secondary"
        android:paddingHorizontal="20dp"
        android:text="Skip Intro"
        android:textAllCaps="false"
        android:textColor="@color/cinematic_text_primary"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/nextEpisodePanel"
        android:layout_width="360dp"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="140dp"
        android:background="@drawable/bg_dialog_premium"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Episode"
            android:textColor="@color/cinematic_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tvNextEpisodeTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="S01E02 • Episode Title" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvNextEpisodeCountdown"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/moplayer_orange_light"
                android:textSize="13sp"
                tools:text="Starts in 10 seconds..." />

            <Button
                android:id="@+id/btnCancelAutoPlay"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnPlayNow"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_button_play"
                android:text="Play Now"
                android:textAllCaps="false"
                android:textColor="@color/htc_pure_black" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/moplayer_orange" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/errorOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog_premium"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_error"
            app:tint="@color/htc_error"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="16sp"
            tools:text="Playback failed." />

        <Button
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="46dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_button_play"
            android:paddingHorizontal="20dp"
            android:text="@string/retry"
            android:textAllCaps="false"
            android:textColor="@color/htc_pure_black" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/externalPlayerDialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#7A000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="360dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_dialog_premium"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_external"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMxPlayer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_secondary"
                android:text="MX Player"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnVlcExternal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_secondary"
                android:text="VLC"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnOtherPlayer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_button_secondary"
                android:text="Other"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnCancelExternal"
                android:layout_width="match_parent"
                android:layout_height="46dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_secondary"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_secondary" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
