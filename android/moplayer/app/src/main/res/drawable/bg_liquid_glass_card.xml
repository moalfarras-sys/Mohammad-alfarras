<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_l" />
            <solid android:color="#2617263F" />
            <stroke
                android:width="@dimen/liquid_focus_stroke"
                android:color="@color/cinematic_focus_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_l" />
            <gradient
                android:angle="315"
                android:startColor="#140E1A32"
                android:endColor="#2213243E" />
            <stroke
                android:width="1dp"
                android:color="@color/liquid_glass_border" />
        </shape>
    </item>
</selector>
