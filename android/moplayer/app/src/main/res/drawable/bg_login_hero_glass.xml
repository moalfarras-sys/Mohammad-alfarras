<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="-6dp"
        android:top="-6dp"
        android:right="-6dp"
        android:bottom="-6dp">
        <shape android:shape="rectangle">
            <corners android:radius="32dp" />
            <gradient
                android:centerX="0.68"
                android:centerY="0.22"
                android:endColor="#00000000"
                android:gradientRadius="260dp"
                android:startColor="@color/login_hero_glow"
                android:type="radial" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="28dp" />
            <gradient
                android:angle="315"
                android:endColor="#D01A2334"
                android:startColor="#C8131B29" />
            <stroke
                android:width="1dp"
                android:color="#42FFFFFF" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="26dp"
                android:topRightRadius="26dp" />
            <gradient
                android:angle="270"
                android:endColor="#00FFFFFF"
                android:startColor="#20FFFFFF" />
            <size android:height="42dp" />
        </shape>
    </item>

</layer-list>
