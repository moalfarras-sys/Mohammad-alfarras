<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Content Card Background with Focus States -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Focus Glow -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#7700E5FF"/>
                    <corners android:radius="@dimen/card_corner_radius"/>
                </shape>
            </item>
            <!-- Card Background with Elevation -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="145"
                        android:startColor="#E8173470"
                        android:centerColor="#D6221B61"
                        android:endColor="#DA092C58" />
                    <stroke
                        android:width="3dp"
                        android:color="#FFFFFFFF"/>
                    <corners android:radius="@dimen/card_corner_radius"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#DD102A5C"/>
            <stroke
                android:width="1dp"
                android:color="@color/cinematic_divider"/>
            <corners android:radius="@dimen/card_corner_radius"/>
        </shape>
    </item>
    
    <!-- Normal State -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="145"
                android:startColor="#BB0B1D3D"
                android:centerColor="#AA111A3F"
                android:endColor="#AA190B30" />
            <stroke
                android:width="1.2dp"
                android:color="#42B9F7FF"/>
            <corners android:radius="@dimen/card_corner_radius"/>
        </shape>
    </item>
</selector>
