<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_m" />
            <solid android:color="@color/liquid_accent_primary_soft" />
            <stroke android:width="2dp" android:color="@color/liquid_focus_ring" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_m" />
            <solid android:color="@color/liquid_accent_primary_pressed" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_m" />
            <solid android:color="@color/liquid_glass_surface" />
            <stroke android:width="1dp" android:color="@color/liquid_glass_border" />
        </shape>
    </item>
</selector>
