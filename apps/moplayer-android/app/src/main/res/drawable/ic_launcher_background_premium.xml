<?xml version="1.0" encoding="utf-8"?>
<!--
    MoPlayer Adaptive Icon Background
    Deep navy space — 108dp canvas, safe zone = inner 72dp circle
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep navy background -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108">
                <item android:offset="0.0" android:color="#0F0F1F"/>
                <item android:offset="0.5" android:color="#0D0D1A"/>
                <item android:offset="1.0" android:color="#12122A"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Electric blue radial glow -->
    <path android:pathData="M54,54m-45,0a45,45 0,1 1,90 0a45,45 0,1 1,-90 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="45">
                <item android:offset="0.0" android:color="#284F8BFF"/>
                <item android:offset="0.6" android:color="#104F8BFF"/>
                <item android:offset="1.0" android:color="#000D0D1A"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Secondary violet accent highlight -->
    <path android:pathData="M54,54m-25,0a25,25 0,1 1,50 0a25,25 0,1 1,-50 0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="25">
                <item android:offset="0.0" android:color="#128B5CF6"/>
                <item android:offset="1.0" android:color="#000D0D1A"/>
            </gradient>
        </aapt:attr>
    </path>

</vector>
