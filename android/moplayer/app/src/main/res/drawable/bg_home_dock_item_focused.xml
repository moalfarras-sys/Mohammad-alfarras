<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Inner cyan glow ring for dock item -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient android:type="radial" android:gradientRadius="80dp"
                android:centerX="0.5" android:centerY="0.5"
                android:startColor="#6600F5FF" android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="18dp" />
            <solid android:color="#2800F5FF" />
            <stroke android:width="2dp" android:color="@color/cinematic_cyan" />
        </shape>
    </item>
</layer-list>
