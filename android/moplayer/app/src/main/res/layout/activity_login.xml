<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/htc_pure_black">

    <com.mo.moplayer.ui.widgets.AnimatedBackground
        android:id="@+id/htcAnimatedBackground"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivLoginCityWallpaper"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:scaleType="centerCrop"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/tv_banner_image" />

    <View
        android:id="@+id/viewLoginWallpaperScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_login_wallpaper_scrim"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.mo.moplayer.ui.widgets.weather.FullScreenWeatherOverlay
        android:id="@+id/weatherOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.65"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.mo.moplayer.ui.widgets.Weather3DWidget
        android:id="@+id/weatherWidget"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="14dp"
        android:alpha="0.38"
        android:scaleX="0.68"
        android:scaleY="0.68"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:alpha="0.52"
        android:background="@drawable/bg_logo_glow_large"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:alpha="0.28"
        android:background="@drawable/bg_logo_glow_outer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/loginCardClean"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_login_hero_glass"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.5"
        app:layout_constraintWidth_max="400dp">

        <LinearLayout
            android:id="@+id/imgLogoClean"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="48dp"
            android:orientation="horizontal"
            android:paddingStart="2dp"
            android:paddingTop="2dp"
            android:paddingEnd="2dp"
            android:paddingBottom="2dp">

            <FrameLayout
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/bg_login_brand_icon">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/cd_logo"
                    android:scaleType="fitCenter"
                    android:src="@drawable/moplayer_brand_logo_new" />

            </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_brand_mo"
                        android:textColor="@color/login_white"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/login_brand_player"
                        android:textColor="@color/moplayer_orange_light"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="@string/login_brand_byline"
                    android:textColor="@color/color_text_primary_80"
                    android:textSize="8sp" />

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_badge_premium"
                android:paddingStart="7dp"
                android:paddingTop="2dp"
                android:paddingEnd="7dp"
                android:paddingBottom="2dp"
                android:text="@string/login_hero_badge"
                android:textColor="@color/login_white"
                android:textSize="7sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical"
                android:paddingStart="4dp"
                android:paddingTop="4dp"
                android:paddingEnd="4dp"
                android:paddingBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_clean_title"
                android:textColor="@color/login_white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/login_form_subtitle"
                android:textColor="@color/color_text_primary_80"
                android:textSize="8sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_login_tab_glass"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="2dp">

                <TextView
                    android:id="@+id/btnTabXtreamClean"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/selector_login_tab_hero"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:nextFocusDown="@id/etServerUrlClean"
                    android:nextFocusRight="@id/btnTabM3uClean"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="Xtream"
                    android:textAllCaps="false"
                    android:textColor="@color/login_white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="3dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/btnTabM3uClean"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/selector_login_tab_hero"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:nextFocusDown="@id/etM3uUrlClean"
                    android:nextFocusLeft="@id/btnTabXtreamClean"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:text="M3U"
                    android:textAllCaps="false"
                    android:textColor="@color/login_white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <ViewFlipper
                android:id="@+id/viewFlipperLoginClean"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:inAnimation="@android:anim/fade_in"
                android:outAnimation="@android:anim/fade_out">

                <LinearLayout
                    android:id="@+id/formXtreamClean"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/etServerUrlClean"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginBottom="5dp"
                        android:background="@drawable/bg_login_input_hero"
                        android:gravity="start|center_vertical"
                        android:hint="Server URL"
                        android:includeFontPadding="false"
                        android:imeOptions="actionNext"
                        android:inputType="textUri"
                        android:layoutDirection="ltr"
                        android:minHeight="0dp"
                        android:nextFocusDown="@id/etUsernameClean"
                        android:nextFocusUp="@id/btnTabXtreamClean"
                        android:paddingStart="10dp"
                        android:paddingTop="0dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="0dp"
                        android:scrollHorizontally="true"
                        android:singleLine="true"
                        android:textColor="@color/login_white"
                        android:textColorHint="@color/color_text_primary_80"
                        android:textDirection="ltr"
                        android:textSize="10sp"
                        tools:ignore="Autofill,LabelFor" />

                    <EditText
                        android:id="@+id/etUsernameClean"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginBottom="5dp"
                        android:background="@drawable/bg_login_input_hero"
                        android:gravity="start|center_vertical"
                        android:hint="Username"
                        android:includeFontPadding="false"
                        android:imeOptions="actionNext"
                        android:inputType="text"
                        android:minHeight="0dp"
                        android:nextFocusDown="@id/etPasswordClean"
                        android:nextFocusUp="@id/etServerUrlClean"
                        android:paddingStart="10dp"
                        android:paddingTop="0dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="0dp"
                        android:scrollHorizontally="true"
                        android:singleLine="true"
                        android:textColor="@color/login_white"
                        android:textColorHint="@color/color_text_primary_80"
                        android:textSize="10sp"
                        tools:ignore="Autofill,LabelFor" />

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginBottom="8dp">

                        <EditText
                            android:id="@+id/etPasswordClean"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/bg_login_input_hero"
                            android:gravity="start|center_vertical"
                            android:hint="Password"
                            android:includeFontPadding="false"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:minHeight="0dp"
                            android:nextFocusDown="@id/btnConnectClean"
                            android:nextFocusUp="@id/etUsernameClean"
                            android:paddingStart="10dp"
                            android:paddingTop="0dp"
                            android:paddingEnd="34dp"
                            android:paddingBottom="0dp"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:textColor="@color/login_white"
                            android:textColorHint="@color/color_text_primary_80"
                            android:textSize="10sp"
                            tools:ignore="Autofill,LabelFor" />

                        <ImageButton
                            android:id="@+id/btnTogglePasswordClean"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="end|center_vertical"
                            android:layout_marginEnd="4dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/cd_toggle_password"
                            android:src="@drawable/ic_visibility_off"
                            app:tint="@color/color_text_hint" />

                    </FrameLayout>

                    <Button
                        android:id="@+id/btnConnectClean"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:background="@drawable/bg_login_button_primary_hero"
                        android:focusable="true"
                        android:nextFocusUp="@id/etPasswordClean"
                        android:stateListAnimator="@null"
                        android:text="@string/btn_connect"
                        android:textAllCaps="false"
                        android:textColor="@color/login_white"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/formM3uClean"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/etM3uUrlClean"
                        android:layout_width="match_parent"
                        android:layout_height="38dp"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_login_input_hero"
                        android:gravity="start|center_vertical"
                        android:hint="M3U Playlist URL"
                        android:includeFontPadding="false"
                        android:imeOptions="actionDone"
                        android:inputType="textUri"
                        android:layoutDirection="ltr"
                        android:minHeight="0dp"
                        android:nextFocusDown="@id/btnImportM3uClean"
                        android:nextFocusUp="@id/btnTabM3uClean"
                        android:paddingStart="10dp"
                        android:paddingTop="0dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="0dp"
                        android:scrollHorizontally="true"
                        android:singleLine="true"
                        android:textColor="@color/login_white"
                        android:textColorHint="@color/color_text_primary_80"
                        android:textDirection="ltr"
                        android:textSize="10sp"
                        tools:ignore="Autofill,LabelFor" />

                    <Button
                        android:id="@+id/btnImportM3uClean"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:layout_marginBottom="6dp"
                        android:background="@drawable/bg_login_button_primary_hero"
                        android:focusable="true"
                        android:nextFocusDown="@id/btnImportM3uLocalClean"
                        android:nextFocusUp="@id/etM3uUrlClean"
                        android:stateListAnimator="@null"
                        android:text="@string/btn_import_m3u"
                        android:textAllCaps="false"
                        android:textColor="@color/login_white"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/color_glass_15" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="10dp"
                            android:text="@string/or_divider"
                            android:textColor="@color/color_text_hint"
                            android:textSize="8sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/color_glass_15" />

                    </LinearLayout>

                    <Button
                        android:id="@+id/btnImportM3uLocalClean"
                        android:layout_width="match_parent"
                        android:layout_height="35dp"
                        android:background="@drawable/bg_login_button_secondary_hero"
                        android:focusable="true"
                        android:nextFocusUp="@id/btnImportM3uClean"
                        android:stateListAnimator="@null"
                        android:text="@string/btn_import_m3u_local"
                        android:textAllCaps="false"
                        android:textColor="@color/login_white"
                        android:textSize="9sp" />

                </LinearLayout>

            </ViewFlipper>

            <TextView
                android:id="@+id/tvErrorClean"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_login_error_chip"
                android:gravity="center"
                android:padding="8dp"
                android:textColor="@color/login_white"
                android:textSize="10sp"
                android:visibility="gone"
                tools:text="Connection error"
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvDeveloperCreditClean"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:alpha="0.24"
        android:text="@string/developer_credit_short"
        android:textColor="@color/login_gray_light"
        android:textSize="10sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <FrameLayout
        android:id="@+id/loadingOverlayClean"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_loading_clean"
        android:clickable="true"
        android:elevation="10dp"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/loadingLogoClean"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_login_brand_icon">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_gravity="center"
                        android:contentDescription="@string/cd_logo"
                        android:scaleType="fitCenter"
                        android:src="@drawable/moplayer_brand_logo_new" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/login_brand_mo"
                            android:textColor="@color/login_white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/login_brand_player"
                            android:textColor="@color/moplayer_orange_light"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/login_brand_byline"
                        android:textColor="@color/color_text_primary_80"
                        android:textSize="9sp" />

                </LinearLayout>

            </LinearLayout>

            <ProgressBar
                android:id="@+id/loadingProgressClean"
                style="?android:attr/progressBarStyleLarge"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:indeterminateTint="@color/login_white" />

            <TextView
                android:id="@+id/tvMarketingTextClean"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:letterSpacing="0.02"
                android:shadowColor="@color/login_white_subtle"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="10"
                android:text="@string/marketing_connecting"
                android:textAlignment="center"
                android:textColor="@color/login_white"
                android:textSize="@dimen/login_marketing_text_size" />

        </LinearLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/tvSignature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:alpha="0.85"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.08"
        android:text="Designed by Moalfarras"
        android:textColor="@color/color_text_primary_80"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
