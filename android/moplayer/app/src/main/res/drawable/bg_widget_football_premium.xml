<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:left="-2dp" android:top="-2dp" android:right="-2dp" android:bottom="-2dp">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <solid android:color="#0D58AFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#D10A1422" />
            <stroke
                android:width="1dp"
                android:color="#1FFFFFFF" />
        </shape>
    </item>

    <item android:top="1dp" android:left="20dp" android:right="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <solid android:color="#12FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>

</layer-list>
