<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Deep space glass background with opacity -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B3040A1C" /> <!-- 70% opacity deep blue/black -->
            <corners android:radius="24dp" />
            <stroke android:width="1dp" android:color="#3300F5FF" />
        </shape>
    </item>
    <!-- Subtle top highlight for 3D glass edge effect -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
