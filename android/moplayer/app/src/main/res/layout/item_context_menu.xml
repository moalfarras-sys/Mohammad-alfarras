<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:focusable="true"
    android:clickable="true"
    android:background="@drawable/selector_menu_item">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingTop="14dp"
        android:paddingEnd="20dp"
        android:paddingBottom="14dp"
        android:gravity="center_vertical">

        <!-- Icon with background circle -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_menu_icon_circle">

            <ImageView
                android:id="@+id/ivMenuIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                app:tint="@color/htc_accent_green"
                tools:src="@drawable/ic_favorite_border"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvMenuTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/htc_text_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium"
            tools:text="إضافة للمفضلة" />

        <!-- Arrow indicator -->
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:alpha="0.4"
            android:src="@drawable/ic_chevron_right"
            app:tint="@color/htc_text_secondary"
            tools:ignore="ContentDescription" />

    </LinearLayout>

</FrameLayout>
