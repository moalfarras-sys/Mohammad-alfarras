<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/weatherDebugScroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:fadeScrollbars="false"
    android:scrollbarThumbVertical="@color/moplayer_orange">

    <LinearLayout
        android:id="@+id/weatherDebugPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_glass_panel_premium"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/weather_debug_title"
            android:textColor="@color/htc_text_primary"
            android:fontFamily="sans-serif-medium"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/weather_debug_desc"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/htc_text_secondary"
            android:textSize="15sp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchWeatherDebugEnabled"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/selector_card_focus"
            android:clickable="true"
            android:focusable="true"
            android:nextFocusDown="@id/spinnerWeatherCategory"
            android:paddingHorizontal="18dp"
            android:text="@string/weather_debug_enable"
            android:textColor="@color/htc_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:checked="false" />

        <!-- Category -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/weather_debug_category"
            android:textColor="@color/moplayer_orange_light"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerWeatherCategory"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/selector_card_focus"
            android:clickable="true"
            android:focusable="true"
            android:nextFocusUp="@id/switchWeatherDebugEnabled"
            android:nextFocusDown="@id/switchWeatherDebugIsDay"
            android:paddingHorizontal="16dp" />

        <!-- Day/Night -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchWeatherDebugIsDay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/selector_card_focus"
            android:clickable="true"
            android:focusable="true"
            android:nextFocusUp="@id/spinnerWeatherCategory"
            android:nextFocusDown="@id/seekTemp"
            android:paddingHorizontal="18dp"
            android:text="@string/weather_debug_day"
            android:textColor="@color/htc_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:checked="true" />

        <!-- Temperature -->
        <TextView
            android:id="@+id/tvTempLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/weather_debug_temp" />

        <SeekBar
            android:id="@+id/seekTemp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_card_focus"
            android:focusable="true"
            android:max="80" />

        <!-- Wind speed -->
        <TextView
            android:id="@+id/tvWindLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/weather_debug_wind" />

        <SeekBar
            android:id="@+id/seekWind"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_card_focus"
            android:focusable="true"
            android:max="120" />

        <!-- Wind direction -->
        <TextView
            android:id="@+id/tvWindDirLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/weather_debug_wind_dir" />

        <SeekBar
            android:id="@+id/seekWindDir"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_card_focus"
            android:focusable="true"
            android:max="360" />

        <!-- Humidity -->
        <TextView
            android:id="@+id/tvHumidityLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/weather_debug_humidity" />

        <SeekBar
            android:id="@+id/seekHumidity"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_card_focus"
            android:focusable="true"
            android:max="100" />

        <!-- Cloud -->
        <TextView
            android:id="@+id/tvCloudLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/weather_debug_cloud" />

        <SeekBar
            android:id="@+id/seekCloud"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_card_focus"
            android:focusable="true"
            android:max="100" />

        <!-- Precip -->
        <TextView
            android:id="@+id/tvPrecipLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:text="@string/weather_debug_precip" />

        <SeekBar
            android:id="@+id/seekPrecip"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/selector_card_focus"
            android:focusable="true"
            android:max="50" />

        <TextView
            android:id="@+id/tvWeatherDebugNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/weather_debug_hint"
            android:textColor="@color/htc_text_tertiary"
            android:textSize="13sp" />

        <LinearLayout
            android:id="@+id/weatherDebugActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="end|center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnWeatherDebugReset"
                android:layout_width="132dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_button_secondary"
                android:focusable="true"
                android:nextFocusRight="@id/btnWeatherDebugCancel"
                android:text="@string/weather_debug_reset"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnWeatherDebugCancel"
                android:layout_width="132dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_button_secondary"
                android:focusable="true"
                android:nextFocusLeft="@id/btnWeatherDebugReset"
                android:nextFocusRight="@id/btnWeatherDebugApply"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnWeatherDebugApply"
                android:layout_width="132dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_button_play"
                android:focusable="true"
                android:nextFocusLeft="@id/btnWeatherDebugCancel"
                android:text="@string/weather_debug_apply"
                android:textAllCaps="false"
                android:textColor="@color/htc_pure_black"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>

