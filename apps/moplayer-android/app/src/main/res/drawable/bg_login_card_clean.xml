<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Frosted Glass Login Card -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Outer Glow Effect -->
    <item
        android:left="-2dp"
        android:top="-2dp"
        android:right="-2dp"
        android:bottom="-2dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0"
                android:startColor="#200A84FF"
                android:endColor="#00000000" />
        </shape>
    </item>
    
    <!-- Frosted Glass Background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="#E61A1A24" />
        </shape>
    </item>
    
    <!-- Inner Glass Layer for Depth -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp"
        android:bottom="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#08FFFFFF"
                android:endColor="#00FFFFFF" />
        </shape>
    </item>
    
    <!-- Glass Border with Blue Tint -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#350A84FF" />
        </shape>
    </item>
    
    <!-- Top Glass Shine Reflection -->
    <item
        android:top="1dp"
        android:left="24dp"
        android:right="24dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="23dp"
                android:topRightRadius="23dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#18FFFFFF"
                android:centerColor="#08FFFFFF"
                android:endColor="#00FFFFFF"
                android:centerY="0.3" />
            <size android:height="50dp" />
        </shape>
    </item>
    
    <!-- Subtle Bottom Shadow -->
    <item
        android:bottom="1dp"
        android:left="30dp"
        android:right="30dp">
        <shape android:shape="rectangle">
            <corners
                android:bottomLeftRadius="23dp"
                android:bottomRightRadius="23dp" />
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="#00000000"
                android:endColor="#10000000" />
            <size android:height="30dp" />
        </shape>
    </item>

</layer-list>
