<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_weather_premium">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="14dp"
        android:paddingEnd="14dp">

        <!-- Animated Weather Icon with glow -->
        <FrameLayout
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginEnd="12dp">

            <View
                android:id="@+id/iconGlow"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:alpha="0.25"
                android:background="@drawable/bg_icon_glow" />

            <com.airbnb.lottie.LottieAnimationView
                android:id="@+id/weatherIconLottie"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:scaleType="centerInside"
                android:visibility="gone"
                app:lottie_autoPlay="true"
                app:lottie_loop="true"
                tools:visibility="visible" />

            <ImageView
                android:id="@+id/ivWeatherIcon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                android:elevation="4dp"
                android:src="@drawable/ic_weather_sunny"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <!-- Temperature + City + Condition -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="start"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTemperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-condensed"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:includeFontPadding="false"
                tools:text="22°" />

            <TextView
                android:id="@+id/tvTemperatureShadow"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                tools:text="" />

            <TextView
                android:id="@+id/tvCity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:alpha="0.9"
                tools:text="Berlin" />

            <TextView
                android:id="@+id/tvCondition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/cinematic_text_secondary"
                android:textSize="11sp"
                android:fontFamily="sans-serif"
                tools:text="Sunny" />

            <TextView
                android:id="@+id/tvUpdated"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone"
                tools:text="" />

        </LinearLayout>

    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/moplayer_orange"
        android:visibility="gone"
        tools:visibility="visible" />

</FrameLayout>
