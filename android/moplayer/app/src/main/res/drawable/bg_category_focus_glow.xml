<?xml version="1.0" encoding="utf-8"?>
<!-- Glow effect for focused category items in Live TV -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="10dp" />
    <gradient
        android:type="radial"
        android:gradientRadius="120dp"
        android:centerX="0.5"
        android:centerY="0.5"
        android:startColor="#6000FF88"
        android:endColor="#0000FF88" />
</shape>
