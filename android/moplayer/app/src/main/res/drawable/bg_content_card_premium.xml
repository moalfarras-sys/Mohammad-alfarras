<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Content Card Background with Focus States -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused State -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Focus Glow -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glow_gold_medium"/>
                    <corners android:radius="@dimen/card_corner_radius"/>
                </shape>
            </item>
            <!-- Card Background with Elevation -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/card_bg_luxury_elevated"/>
                    <stroke
                        android:width="2dp"
                        android:color="@color/card_border_luxury"/>
                    <corners android:radius="@dimen/card_corner_radius"/>
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed State -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_bg_luxury"/>
            <stroke
                android:width="1dp"
                android:color="@color/card_border_luxury_subtle"/>
            <corners android:radius="@dimen/card_corner_radius"/>
        </shape>
    </item>
    
    <!-- Normal State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/htc_card_background"/>
            <stroke
                android:width="1dp"
                android:color="@color/htc_card_border"/>
            <corners android:radius="@dimen/card_corner_radius"/>
        </shape>
    </item>
</selector>
