<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cinematic_bg_base">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_live_cinematic_base" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="14dp"
        android:paddingBottom="12dp">

        <!-- ===== Header ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/epg_header_height"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:tag="accent_icon"
                android:src="@drawable/ic_guide"
                app:tint="@color/liquid_accent_primary"
                tools:ignore="ContentDescription" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="@font/dmsans_medium"
                android:tag="accent_text"
                android:text="@string/epg_guide_title"
                android:textColor="@color/liquid_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGuideChannelCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_count_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:textColor="@color/liquid_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                tools:text="245 channels" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Day navigation -->
            <ImageButton
                android:id="@+id/btnPrevDay"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/selector_tv_button"
                android:contentDescription="@string/epg_prev_day"
                android:focusable="true"
                android:src="@drawable/ic_chevron_left"
                app:tint="@color/liquid_text_primary" />

            <TextView
                android:id="@+id/tvDayLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="6dp"
                android:fontFamily="@font/dmsans_medium"
                android:gravity="center"
                android:minWidth="148dp"
                android:textColor="@color/liquid_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="Today · Wed, Jun 3" />

            <ImageButton
                android:id="@+id/btnNextDay"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/selector_tv_button"
                android:contentDescription="@string/epg_next_day"
                android:focusable="true"
                android:src="@drawable/ic_chevron_right"
                app:tint="@color/liquid_text_primary" />

            <TextView
                android:id="@+id/btnJumpNow"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_epg_chip"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="@font/dmsans_medium"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="@string/epg_jump_now"
                android:textColor="@color/liquid_text_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvGuideClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/dmsans_regular"
                android:tag="accent_text"
                android:textColor="@color/liquid_accent_primary"
                android:textSize="26sp"
                android:textStyle="bold"
                tools:text="14:35" />

        </LinearLayout>

        <!-- ===== Category chips ===== -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvGuideCategories"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            tools:listitem="@layout/item_guide_category" />

        <!-- ===== Timeline header (channel column header + time ruler) ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/epg_ruler_height"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:layout_width="@dimen/epg_channel_col_width"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:text="@string/live_tv_channel_list"
                android:textColor="@color/liquid_text_tertiary"
                android:textSize="11sp"
                android:textStyle="bold" />

            <com.mo.moplayer.ui.epg.EpgTimeRulerView
                android:id="@+id/timeRuler"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_glass_15" />

        <!-- ===== Grid ===== -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGuide"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:descendantFocusability="afterDescendants"
                android:scrollbars="none" />

            <ProgressBar
                android:id="@+id/guideLoading"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/liquid_accent_primary"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/guideEmpty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:alpha="0.6"
                    android:src="@drawable/ic_live_tv"
                    app:tint="@color/liquid_text_tertiary"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/epg_empty"
                    android:textColor="@color/liquid_text_secondary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

        </FrameLayout>

        <!-- ===== Focused-program details ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/epg_details_height"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_panel_floating_glass"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingVertical="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDetailTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/dmsans_medium"
                    android:textColor="@color/liquid_accent_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="14:30 - 15:00" />

                <TextView
                    android:id="@+id/tvDetailChannel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/liquid_text_tertiary"
                    android:textSize="12sp"
                    tools:text="Discovery Channel HD" />

                <TextView
                    android:id="@+id/tvDetailHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="@string/epg_guide_hint"
                    android:textColor="@color/liquid_text_tertiary"
                    android:textSize="11sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/tvDetailTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:fontFamily="@font/dmsans_medium"
                android:maxLines="1"
                android:textColor="@color/liquid_text_primary"
                android:textSize="17sp"
                android:textStyle="bold"
                tools:text="Shark Week: Great White Encounter" />

            <TextView
                android:id="@+id/tvDetailDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/liquid_text_secondary"
                android:textSize="13sp"
                tools:text="A deep dive into the behaviour of great white sharks off the South African coast." />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
