<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Tab Button - Blue Theme for TV -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/cinematic_surface_alt" />
            <stroke android:width="2dp" android:color="@color/cinematic_focus_soft" />
        </shape>
    </item>
    
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/cinematic_surface_alt" />
            <stroke android:width="2dp" android:color="@color/cinematic_focus_soft" />
        </shape>
    </item>
    
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/cinematic_surface" />
            <stroke android:width="1dp" android:color="@color/cinematic_divider" />
        </shape>
    </item>
    
</selector>
