<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#26233A4D" />
                </shape>
            </item>
            <item android:width="4dp" android:gravity="start">
                <shape android:shape="rectangle">
                    <solid android:color="@color/liquid_accent_primary" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="#1A233A4D" />
                </shape>
            </item>
            <item android:width="4dp" android:gravity="start">
                <shape android:shape="rectangle">
                    <solid android:color="#80233A4D" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
