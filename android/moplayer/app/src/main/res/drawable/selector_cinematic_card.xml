<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-2dp"
                android:top="-2dp"
                android:right="-2dp"
                android:bottom="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="22dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="120dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#184F8BFF"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/cinematic_radius_card" />
                    <solid android:color="@color/cinematic_surface_alt" />
                    <stroke android:width="@dimen/cinematic_stroke_focus" android:color="@color/liquid_focus_ring" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/cinematic_radius_card" />
            <solid android:color="@color/cinematic_surface" />
            <stroke android:width="1dp" android:color="@color/cinematic_divider" />
        </shape>
    </item>
</selector>
