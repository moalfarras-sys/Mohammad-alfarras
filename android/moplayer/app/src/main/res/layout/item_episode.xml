<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp">

    <LinearLayout
        android:id="@+id/episodeContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_episode_item"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Thumbnail with rounded corners -->
        <FrameLayout
            android:layout_width="100dp"
            android:layout_height="60dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivThumbnail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#15FFFFFF"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_content_placeholder"
                    tools:ignore="ContentDescription" />

                <!-- Progress Overlay -->
                <LinearLayout
                    android:id="@+id/progressOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="#99000000"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:visibility="gone"
                    tools:visibility="visible">

                    <ProgressBar
                        android:id="@+id/progressBar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="3dp"
                        android:max="100"
                        android:progress="65"
                        android:progressDrawable="@drawable/bg_progress_bar" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Play Icon -->
            <FrameLayout
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_play_button_small">

                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play"
                    app:tint="@color/htc_pure_white"
                    tools:ignore="ContentDescription" />

            </FrameLayout>

        </FrameLayout>

        <!-- Episode Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Episode Number Badge + Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvEpisodeNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_episode_number"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:textColor="@color/htc_accent_green"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="E1" />

                <TextView
                    android:id="@+id/tvEpisodeTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/htc_text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    tools:text="Pilot" />

            </LinearLayout>

            <!-- Duration + Watched indicator -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/htc_text_tertiary"
                    android:textSize="10sp"
                    tools:text="58 min" />

                <ImageView
                    android:id="@+id/ivWatched"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_check_circle"
                    android:visibility="gone"
                    app:tint="@color/htc_accent_green"
                    tools:ignore="ContentDescription"
                    tools:visibility="visible" />

            </LinearLayout>

            <!-- Plot (optional) -->
            <TextView
                android:id="@+id/tvEpisodePlot"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/htc_text_secondary"
                android:textSize="10sp"
                android:visibility="gone"
                tools:text="Walter White, a high school chemistry teacher diagnosed with terminal lung cancer, turns to making meth with a former student."
                tools:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
