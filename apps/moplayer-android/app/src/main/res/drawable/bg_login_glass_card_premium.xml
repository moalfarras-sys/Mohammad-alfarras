<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Login Card - Clean Solid Design with Blue accent -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Main solid background -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <solid android:color="@color/htc_dark_gray" />
            <stroke
                android:width="1dp"
                android:color="@color/htc_silver" />
        </shape>
    </item>
    
    <!-- Subtle top accent line -->
    <item android:left="40dp" android:right="40dp" android:top="0dp">
        <shape android:shape="rectangle">
            <size android:height="2dp" />
            <solid android:color="@color/htc_accent_green" />
        </shape>
    </item>

</layer-list>
