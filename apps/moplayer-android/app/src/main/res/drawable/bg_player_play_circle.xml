<?xml version="1.0" encoding="utf-8"?>
<!-- MoPlayer — primary Play/Pause control: a bold electric-cyan circle with a
     soft focus halo. Pairs with a dark icon tint for maximum on-TV contrast. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- FOCUSED -->
    <item android:state_focused="true">
        <layer-list>
            <item android:left="-7dp" android:top="-7dp" android:right="-7dp" android:bottom="-7dp">
                <shape android:shape="oval">
                    <gradient
                        android:type="radial"
                        android:gradientRadius="74dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#8000E5FF"
                        android:endColor="#0000E5FF" />
                </shape>
            </item>
            <item>
                <shape android:shape="oval">
                    <gradient
                        android:type="linear"
                        android:angle="90"
                        android:startColor="@color/cinematic_cyan_light"
                        android:endColor="@color/cinematic_cyan" />
                    <stroke android:width="2.5dp" android:color="#F2FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- PRESSED -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/cinematic_cyan_dark" />
            <stroke android:width="2dp" android:color="#A6FFFFFF" />
        </shape>
    </item>

    <!-- DEFAULT -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="90"
                android:startColor="@color/cinematic_cyan_dark"
                android:endColor="@color/cinematic_cyan" />
            <stroke android:width="1.5dp" android:color="#3DFFFFFF" />
        </shape>
    </item>

</selector>
