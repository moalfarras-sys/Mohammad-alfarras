<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cardContainer"
    android:layout_width="@dimen/card_poster_width"
    android:layout_height="@dimen/card_content_height"
    android:layout_marginStart="6dp"
    android:layout_marginEnd="6dp"
    android:focusable="true"
    android:clickable="true"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="@android:color/transparent">

    <View
        android:id="@+id/focusGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@drawable/bg_liquid_focus_glow" />

    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/card_poster_height">

            <androidx.cardview.widget.CardView
                android:id="@+id/posterCard"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="@dimen/cinematic_radius_card"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/cinematic_bg_elevated">

                <ImageView
                    android:id="@+id/ivPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_content_placeholder"
                    tools:ignore="ContentDescription" />

                <!-- Bottom gradient for title readability -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/gradient_bottom_overlay" />

                <!-- Top-left glass reflection highlight -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_gravity="top"
                    android:alpha="0.08"
                    android:background="@drawable/bg_poster_gradient" />
            </androidx.cardview.widget.CardView>

            <View
                android:id="@+id/focusBorder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_liquid_focus_ring"
                android:alpha="0" />

            <FrameLayout
                android:id="@+id/ratingBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_rating_badge_premium"
                android:paddingHorizontal="7dp"
                android:paddingVertical="3dp"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cinematic_text_primary"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    tools:text="8.5" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvYear"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_margin="8dp"
                android:background="@drawable/bg_year_badge"
                android:paddingHorizontal="7dp"
                android:paddingVertical="3dp"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                android:visibility="gone"
                tools:text="2024"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/tvQuality"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:background="@drawable/bg_quality_badge_premium"
                android:paddingHorizontal="7dp"
                android:paddingVertical="3dp"
                android:textColor="@color/cinematic_bg_base"
                android:textSize="8sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:visibility="gone"
                tools:text="4K"
                tools:visibility="visible" />

            <ProgressBar
                android:id="@+id/progressWatch"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_gravity="bottom"
                android:max="100"
                android:progress="35"
                android:progressTint="@color/moplayer_orange"
                android:progressBackgroundTint="#200B0F1A"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="7dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:ellipsize="end"
            android:gravity="start"
            android:maxLines="2"
            android:minLines="1"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="@dimen/card_title_size"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.08"
            android:alpha="0.92"
            tools:text="Movie Title Here" />
    </LinearLayout>
</FrameLayout>
