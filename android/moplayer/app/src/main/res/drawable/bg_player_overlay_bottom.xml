<?xml version="1.0" encoding="utf-8"?>
<!-- Player Bottom Controls Overlay Background -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Gradient from transparent to dark -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="@color/htc_player_overlay"
                android:centerColor="@color/htc_overlay_medium"
                android:endColor="#00000000"
                android:type="linear" />
        </shape>
    </item>

    <!-- Top edge highlight -->
    <item android:gravity="top">
        <shape android:shape="rectangle">
            <size android:height="1dp" />
            <solid android:color="@color/htc_glass_border" />
        </shape>
    </item>

</layer-list>
