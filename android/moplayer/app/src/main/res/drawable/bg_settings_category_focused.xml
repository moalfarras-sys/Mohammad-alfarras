<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="-2dp"
        android:top="-2dp"
        android:right="-2dp"
        android:bottom="-2dp">
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="132dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#305DEBFF"
                android:endColor="#00000000" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="14dp" />
            <gradient
                android:angle="135"
                android:startColor="#2533D5FF"
                android:endColor="#1B7257FF" />
            <stroke android:width="2dp" android:color="#A05DEBFF" />
        </shape>
    </item>
</layer-list>
