<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/edittext_corner_radius" />
            <solid android:color="@color/htc_dark_gray" />
            <stroke
                android:width="2dp"
                android:color="@color/htc_accent_green" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/edittext_corner_radius" />
            <solid android:color="@color/htc_dark_gray" />
            <stroke
                android:width="1dp"
                android:color="@color/htc_card_border" />
        </shape>
    </item>

</selector>
