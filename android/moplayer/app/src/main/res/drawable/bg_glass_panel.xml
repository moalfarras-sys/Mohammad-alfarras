<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/glass_corner_radius" />
            <gradient
                android:angle="315"
                android:startColor="@color/liquid_glass_surface"
                android:endColor="@color/liquid_glass_surface_strong" />
            <stroke
                android:width="1dp"
                android:color="@color/liquid_glass_border" />
        </shape>
    </item>

    <item
        android:left="1dp"
        android:top="1dp"
        android:right="1dp">
        <shape android:shape="rectangle">
            <corners
                android:topLeftRadius="15dp"
                android:topRightRadius="15dp" />
            <gradient
                android:angle="270"
                android:startColor="@color/liquid_glass_highlight"
                android:endColor="#00FFFFFF" />
            <size android:height="28dp" />
        </shape>
    </item>
</layer-list>
