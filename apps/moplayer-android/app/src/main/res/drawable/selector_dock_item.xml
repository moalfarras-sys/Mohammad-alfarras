<?xml version="1.0" encoding="utf-8"?>
<!-- Premium cyan dock item selector -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state - controlled cyan glow -->
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="60dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="@color/moplayer_orange_subtle"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/moplayer_orange" />
                    <solid android:color="#1400E5FF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Selected state - subtle cyan -->
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/moplayer_orange_subtle" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>

</selector>
