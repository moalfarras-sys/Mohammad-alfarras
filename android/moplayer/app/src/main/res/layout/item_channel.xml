<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="3dp"
    android:layout_marginHorizontal="4dp">

    <!-- Glow effect when focused -->
    <View
        android:id="@+id/focusGlow"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@drawable/bg_channel_item_glow" />

    <LinearLayout
        android:id="@+id/channelContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_channel_item_premium"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingVertical="12dp"
        android:paddingHorizontal="14dp"
        android:focusable="true"
        android:clickable="true">

        <!-- Channel Number with accent background -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="36dp">

            <View
                android:id="@+id/numberBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_channel_number" />

            <TextView
                android:id="@+id/tvChannelNumber"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/htc_text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                tools:text="125" />
        </FrameLayout>

        <!-- Channel Logo with rounded corners -->
        <androidx.cardview.widget.CardView
            android:layout_width="64dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <ImageView
                android:id="@+id/ivChannelLogo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerInside"
                android:background="#10FFFFFF"
                android:padding="4dp"
                android:src="@drawable/ic_placeholder_channel"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <!-- Channel Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <!-- Channel Name -->
            <TextView
                android:id="@+id/tvChannelName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/htc_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                tools:text="Discovery Channel HD" />

            <!-- EPG Info (Now Playing) -->
            <TextView
                android:id="@+id/tvEpgInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/htc_text_tertiary"
                android:textSize="11sp"
                android:visibility="gone"
                tools:text="Shark Week - Episode 5"
                tools:visibility="visible" />
        </LinearLayout>

        <!-- Quality Badge -->
        <TextView
            android:id="@+id/tvQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_quality_badge_channel"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:textColor="@color/htc_pure_black"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="HD"
            tools:visibility="visible" />

        <!-- Now Playing Indicator -->
        <View
            android:id="@+id/nowPlayingIndicator"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_now_playing_animated"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>

</FrameLayout>
