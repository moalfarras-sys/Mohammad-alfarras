<?xml version="1.0" encoding="utf-8"?>
<!-- MoPlayer: Premium Cinematic Background — Deep Space with Cyber Nebula -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: Deep space base — ultra-dark navy -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:startColor="#000308"
                android:centerColor="#04102A"
                android:endColor="#100520" />
        </shape>
    </item>

    <!-- Layer 2: Cyan nebula glow — top-left -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="700dp"
                android:centerX="0.08"
                android:centerY="0.05"
                android:startColor="#445B7CFF"
                android:centerColor="#1A5B7CFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Layer 3: Violet nebula — top-right -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="600dp"
                android:centerX="0.92"
                android:centerY="0.12"
                android:startColor="#44F4B860"
                android:centerColor="#1A7C3AED"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Layer 4: Deep blue mid-center glow -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0.6"
                android:startColor="#100A1F3A"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Layer 5: Bottom vignette for depth -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="1400dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#00000000"
                android:centerColor="#18000000"
                android:endColor="#E0000000" />
        </shape>
    </item>

</layer-list>
