<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphism surface with Neon Cyan border for focused/active panels -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow ring (simulated with stroke + padding) -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1100F0FF" />
            <corners android:radius="26dp" />
        </shape>
    </item>
    <!-- Neon Cyan border -->
    <item android:top="2dp" android:left="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1.5dp"
                android:color="#5500F0FF" />
            <solid android:color="#0A00F0FF" />
            <corners android:radius="24dp" />
        </shape>
    </item>
    <!-- Inner frosted glass -->
    <item android:top="3dp" android:left="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#0DFFFFFF" />
            <corners android:radius="23dp" />
        </shape>
    </item>
    <!-- Top highlight -->
    <item android:top="4dp" android:left="4dp" android:right="4dp">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#10FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="270" />
            <corners android:radius="22dp" />
        </shape>
    </item>
</layer-list>
