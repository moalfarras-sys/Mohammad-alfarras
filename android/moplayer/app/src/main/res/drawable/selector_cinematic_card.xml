<?xml version="1.0" encoding="utf-8"?>
<!-- MoPlayer — Cinematic Card Focus Selector (TV Premium) -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- FOCUSED — vivid cyan ring + bright glow -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Outer glow aura -->
            <item
                android:left="-5dp"
                android:top="-5dp"
                android:right="-5dp"
                android:bottom="-5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="22dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="160dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#3300F5FF"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <!-- Card body with highlight -->
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <solid android:color="@color/cinematic_surface_alt" />
                    <stroke android:width="2dp" android:color="@color/cinematic_cyan" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- DEFAULT -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="16dp" />
            <solid android:color="@color/cinematic_surface" />
            <stroke android:width="1dp" android:color="@color/cinematic_divider" />
        </shape>
    </item>

</selector>
