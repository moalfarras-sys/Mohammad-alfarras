<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Dim background: focusable/clickable so focus and clicks stay in overlay -->
    <View
        android:id="@+id/weatherDetailsScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <!-- Center card -->
    <LinearLayout
        android:id="@+id/weatherDetailsCard"
        android:layout_width="560dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_glass_panel_premium"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingVertical="22dp"
        tools:ignore="UselessParent">

        <TextView
            android:id="@+id/tvWeatherDetailsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/weather_details_title"
            android:textColor="@color/htc_text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWeatherDetailsCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/htc_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Damascus" />

        <TextView
            android:id="@+id/tvWeatherDetailsCondition"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/htc_text_secondary"
            android:textSize="14sp"
            tools:text="Cloudy" />

        <TextView
            android:id="@+id/tvWeatherDetailsTemp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/htc_text_primary"
            android:textSize="48sp"
            android:textStyle="bold"
            tools:text="-2°" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvWeatherDetailsFeelsLike"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                tools:text="Feels like: -6°" />

            <TextView
                android:id="@+id/tvWeatherDetailsHumidity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                tools:text="Humidity: 72%" />

            <TextView
                android:id="@+id/tvWeatherDetailsWind"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                tools:text="Wind: 12 km/h (250°)" />

            <TextView
                android:id="@+id/tvWeatherDetailsGust"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                tools:text="Gust: 22 km/h" />

            <TextView
                android:id="@+id/tvWeatherDetailsPrecip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                tools:text="Precip: 0.2 mm" />

            <TextView
                android:id="@+id/tvWeatherDetailsCloud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                tools:text="Cloud: 90%" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvWeatherDetailsUpdated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:textColor="@color/htc_text_tertiary"
            android:textSize="13sp"
            tools:text="Updated: 5 min ago" />

        <Button
            android:id="@+id/btnWeatherDetailsClose"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/selector_glass_button"
            android:focusable="true"
            android:text="@string/weather_details_close"
            android:textAllCaps="false"
            android:textColor="@color/htc_text_primary"
            android:textStyle="bold" />

    </LinearLayout>

</merge>
