<?xml version="1.0" encoding="utf-8"?>
<!-- D-pad focus feedback for player controls: a quick, springy scale-up so the focused
     control is unmistakable from across the room. Pairs with the cyan ring in the button bg. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:valueTo="1.18"
                android:valueType="floatType"
                android:duration="160"
                android:interpolator="@android:interpolator/overshoot" />
            <objectAnimator
                android:propertyName="scaleY"
                android:valueTo="1.18"
                android:valueType="floatType"
                android:duration="160"
                android:interpolator="@android:interpolator/overshoot" />
        </set>
    </item>
    <item>
        <set>
            <objectAnimator
                android:propertyName="scaleX"
                android:valueTo="1.0"
                android:valueType="floatType"
                android:duration="140" />
            <objectAnimator
                android:propertyName="scaleY"
                android:valueTo="1.0"
                android:valueType="floatType"
                android:duration="140" />
        </set>
    </item>
</selector>
