<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item
        android:left="-6dp"
        android:top="-6dp"
        android:right="-6dp"
        android:bottom="-6dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.45"
                android:gradientRadius="56dp"
                android:startColor="#365E9EFF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:angle="315"
                android:startColor="#C5162132"
                android:endColor="#D3283550" />
            <stroke
                android:width="1dp"
                android:color="#50FFFFFF" />
        </shape>
    </item>

    <item
        android:left="2dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="2dp">
        <shape android:shape="oval">
            <stroke
                android:width="1dp"
                android:color="#18FFFFFF" />
        </shape>
    </item>

</layer-list>
