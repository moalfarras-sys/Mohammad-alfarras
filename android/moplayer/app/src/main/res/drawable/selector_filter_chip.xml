<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true" android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <solid android:color="@color/liquid_accent_primary" />
                    <stroke android:width="2dp" android:color="#60FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="@color/liquid_accent_primary" />
        </shape>
    </item>
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <gradient
                        android:angle="135"
                        android:startColor="@color/liquid_glass_surface_strong"
                        android:endColor="@color/liquid_glass_surface" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/liquid_focus_ring" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#12FFFFFF" />
            <stroke android:width="1dp" android:color="#18FFFFFF" />
        </shape>
    </item>
</selector>
