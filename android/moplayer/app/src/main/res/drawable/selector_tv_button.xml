<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused and pressed -->
    <item android:state_focused="true" android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/moplayer_orange_dark" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Focused -->
    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-2dp"
                android:top="-2dp"
                android:right="-2dp"
                android:bottom="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="80dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#304F8BFF"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="@color/liquid_glass_surface_strong"
                        android:endColor="@color/liquid_glass_surface" />
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="2dp"
                        android:color="@color/liquid_focus_ring" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/liquid_glass_surface_strong" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Normal - Glass surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/liquid_glass_surface"
                android:endColor="#200D0D1A" />
            <stroke
                android:width="1dp"
                android:color="@color/liquid_glass_border" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>
