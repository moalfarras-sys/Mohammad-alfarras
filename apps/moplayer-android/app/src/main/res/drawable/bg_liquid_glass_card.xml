<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_l" />
            <gradient
                android:angle="315"
                android:startColor="#D00A3B4C"
                android:centerColor="#C80C3047"
                android:endColor="#C80A1C33" />
            <stroke
                android:width="2dp"
                android:color="#D000B8C7" />
        </shape>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_l" />
            <gradient
                android:angle="315"
                android:startColor="#3022B8D4"
                android:endColor="#2514475C" />
            <stroke
                android:width="2dp"
                android:color="#8A63D7EA" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/liquid_radius_l" />
            <gradient
                android:angle="315"
                android:startColor="#3A071427"
                android:endColor="#4D081726" />
            <stroke
                android:width="1dp"
                android:color="#2F8FB6CC" />
        </shape>
    </item>
</selector>
