<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <!-- ExoPlayer SurfaceView (primary engine) -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/exoPlayerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:keepScreenOn="true"
        app:use_controller="false"
        app:surface_type="surface_view" />

    <!-- VLC Video Layout (fallback engine) -->
    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlcVideoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true"
        android:visibility="visible" />

    <!-- Cinematic top + bottom scrims so chrome stays legible over any frame -->
    <View
        android:id="@+id/topScrim"
        android:layout_width="match_parent"
        android:layout_height="@dimen/player_top_scrim_height"
        android:layout_gravity="top"
        android:background="@drawable/bg_player_top_gradient"
        android:visibility="gone"
        tools:visibility="visible" />

    <View
        android:id="@+id/bottomScrim"
        android:layout_width="match_parent"
        android:layout_height="@dimen/player_bottom_scrim_height"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_player_bottom_gradient"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- ══════════════════ TOP BAR: back · title/metadata · clock ══════════════════ -->
    <LinearLayout
        android:id="@+id/topControlsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="40dp"
        android:paddingTop="28dp"
        android:paddingEnd="40dp"
        android:paddingBottom="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_player_icon_btn"
            android:contentDescription="@string/cd_back"
            android:padding="15dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_back"
            android:stateListAnimator="@animator/player_focus_pop"
            app:tint="@color/cinematic_text_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="22dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:shadowColor="#B3000000"
                android:shadowDx="0"
                android:shadowDy="2"
                android:shadowRadius="8"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="27sp"
                android:textStyle="bold"
                tools:text="Inception" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/liveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_live_badge"
                    android:drawablePadding="6dp"
                    android:paddingHorizontal="11dp"
                    android:paddingVertical="4dp"
                    android:text="● LIVE"
                    android:textColor="@android:color/white"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cinematic_text_secondary"
                    android:textSize="14sp"
                    tools:text="Movie" />

                <TextView
                    android:id="@+id/tvPlaybackMeta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/cinematic_text_tertiary"
                    android:textSize="13sp"
                    tools:text="• Premier League • 67'" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCurrentTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:letterSpacing="0.02"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="20sp"
            android:textStyle="bold"
            tools:text="21:36" />
    </LinearLayout>

    <!-- ══════════════════ BOTTOM CONTROL DECK (floating frosted glass) ══════════════════ -->
    <LinearLayout
        android:id="@+id/bottomControlsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/bg_player_bottom_bar"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingTop="18dp"
        android:paddingEnd="30dp"
        android:paddingBottom="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Scrubber: elapsed · seek · duration (hidden for live streams) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPosition"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:fontFeatureSettings="tnum"
                android:gravity="start"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                tools:text="00:14" />

            <SeekBar
                android:id="@+id/seekBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_weight="1"
                android:max="100"
                android:progress="35"
                android:secondaryProgress="55"
                android:maxHeight="8dp"
                android:minHeight="8dp"
                android:paddingTop="15dp"
                android:paddingBottom="15dp"
                android:nextFocusDown="@id/btnPlayPause"
                android:progressDrawable="@drawable/bg_player_seekbar"
                android:thumb="@drawable/bg_player_scrubber_thumb"
                android:thumbOffset="0dp" />

            <TextView
                android:id="@+id/tvDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="60dp"
                android:fontFeatureSettings="tnum"
                android:gravity="end"
                android:textColor="@color/cinematic_text_secondary"
                android:textSize="15sp"
                tools:text="02:20" />
        </LinearLayout>

        <!-- Controls: transport cluster (left) · utilities (right), one D-pad row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnPreviousChannel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_player_icon_btn"
                android:contentDescription="@string/nav_live"
                android:padding="13dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_skip_previous"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnRewind"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="13dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_rewind"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="62dp"
                android:layout_height="62dp"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="14dp"
                android:background="@drawable/bg_player_play_circle"
                android:padding="17dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_pause"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/htc_pure_black" />

            <ImageButton
                android:id="@+id/btnForward"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="13dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_forward"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnNextChannel"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_player_icon_btn"
                android:contentDescription="@string/nav_live"
                android:padding="13dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_skip_next"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <!-- pushes the utility cluster to the right edge -->
            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnGuide"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="11dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_live_tv"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnSubtitles"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="11dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_subtitles"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnAudio"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="11dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_audio"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnSpeed"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="11dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_speed"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnAspectRatio"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="11dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_aspect_ratio"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />

            <ImageButton
                android:id="@+id/btnExternalPlayer"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_player_icon_btn"
                android:padding="11dp"
                android:nextFocusUp="@id/seekBar"
                android:src="@drawable/ic_external"
                android:stateListAnimator="@animator/player_focus_pop"
                app:tint="@color/cinematic_text_primary" />
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════════════ OVERLAYS ══════════════════ -->
    <FrameLayout
        android:id="@+id/optionSheet"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#99000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="@dimen/player_sheet_width"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="40dp"
            android:background="@drawable/bg_glass_panel_premium"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:id="@+id/tvOptionSheetTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="Audio Tracks" />

            <LinearLayout
                android:id="@+id/optionSheetContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="vertical" />
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/channelDrawer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="@dimen/player_drawer_width"
            android:layout_height="match_parent"
            android:background="@drawable/bg_dialog_premium"
            android:orientation="vertical"
            android:padding="22dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/player_quick_guide"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCurrentProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="15sp"
                tools:text="Now • Main Event Coverage" />

            <TextView
                android:id="@+id/tvNextProgram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/cinematic_text_secondary"
                android:textSize="13sp"
                tools:text="Next • Studio Analysis" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:id="@+id/channelListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- Buffering: clean borderless ring centered over the frame -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="66dp"
            android:layout_height="66dp"
            android:indeterminateTint="@color/cinematic_cyan" />

        <TextView
            android:id="@+id/tvLoadingMessage"
            android:layout_width="320dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="2"
            android:text="@string/player_opening_stream"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/errorOverlay"
        android:layout_width="460dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/bg_dialog_premium"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_error"
            app:tint="@color/htc_error"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tvErrorMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:textColor="@color/cinematic_text_primary"
            android:textSize="16sp"
            tools:text="Playback failed." />

        <TextView
            android:id="@+id/tvErrorSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/cinematic_text_tertiary"
            android:textSize="13sp"
            tools:text="BBC News · Live TV" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnErrorBack"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_button_secondary"
                android:focusable="true"
                android:nextFocusRight="@id/btnRetry"
                android:stateListAnimator="@animator/player_focus_pop"
                android:text="@string/back"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnRetry"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                android:layout_weight="1.2"
                android:background="@drawable/bg_button_play"
                android:focusable="true"
                android:nextFocusLeft="@id/btnErrorBack"
                android:stateListAnimator="@animator/player_focus_pop"
                android:text="@string/retry"
                android:textAllCaps="false"
                android:textColor="@color/htc_pure_black"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/externalPlayerDialog"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#A6000000"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="@dimen/player_sheet_width"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_dialog_premium"
            android:orientation="vertical"
            android:padding="26dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/player_external"
                android:textColor="@color/cinematic_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnMxPlayer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_button_secondary"
                android:stateListAnimator="@animator/player_focus_pop"
                android:text="MX Player"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnVlcExternal"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:stateListAnimator="@animator/player_focus_pop"
                android:text="VLC"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnOtherPlayer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button_secondary"
                android:stateListAnimator="@animator/player_focus_pop"
                android:text="Other"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_primary" />

            <Button
                android:id="@+id/btnCancelExternal"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_button_secondary"
                android:stateListAnimator="@animator/player_focus_pop"
                android:text="@string/cancel"
                android:textAllCaps="false"
                android:textColor="@color/cinematic_text_secondary" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
