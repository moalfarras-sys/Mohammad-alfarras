<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_football_premium">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <!-- Football icon -->
        <ImageView
            android:id="@+id/ivFootballIcon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginEnd="12dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_football"
            app:tint="@color/cinematic_text_primary" />

        <!-- Match content or state message -->
        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/matchContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="start">

                <!-- Teams and score row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivHomeLogo"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        tools:src="@drawable/ic_football" />

                    <TextView
                        android:id="@+id/tvHomeTeam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:maxWidth="100dp"
                        android:textColor="@color/cinematic_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        tools:text="Man Utd" />

                    <TextView
                        android:id="@+id/tvScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10dp"
                        android:textColor="@color/moplayer_orange"
                        android:textSize="17sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        tools:text="2 - 1" />

                    <ImageView
                        android:id="@+id/ivAwayLogo"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@null"
                        tools:src="@drawable/ic_football" />

                    <TextView
                        android:id="@+id/tvAwayTeam"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:maxWidth="100dp"
                        android:textColor="@color/cinematic_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        tools:text="Chelsea" />

                    <View
                        android:layout_width="0dp"
                        android:layout_height="0dp"
                        android:layout_weight="1" />

                    <!-- LIVE badge -->
                    <TextView
                        android:id="@+id/tvLiveBadge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_live_badge"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="3dp"
                        android:text="@string/football_widget_live"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- League / minute row -->
                <TextView
                    android:id="@+id/tvLeagueMinute"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/cinematic_text_tertiary"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif"
                    tools:text="Premier League · 67'" />

            </LinearLayout>

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:visibility="gone"
                tools:visibility="visible">

                <ImageView
                    android:id="@+id/ivEmptyIcon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/cinematic_text_secondary"
                    android:layout_marginEnd="@dimen/spacing_8"
                    android:alpha="0.7"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:id="@+id/tvStateMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/cinematic_text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    tools:text="No Live Matches" />
            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:indeterminateTint="@color/moplayer_orange"
        tools:visibility="visible" />

</FrameLayout>
