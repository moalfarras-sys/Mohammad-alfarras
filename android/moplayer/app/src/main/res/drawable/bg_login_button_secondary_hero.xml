<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#3D24334F" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#4A223450" />
            <stroke
                android:width="2dp"
                android:color="#8AC7E5FF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#2C22314A" />
            <stroke
                android:width="1dp"
                android:color="#2BFFFFFF" />
        </shape>
    </item>

</selector>
