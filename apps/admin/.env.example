###############################################################################
# admin.moalfarras.space — public env template
# Copy to .env.local and fill in real values. Never commit real secrets.
###############################################################################

# Admin auth (same scheme as apps/web)
ADMIN_ALLOWLIST="you@example.com"
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD_HASH="scrypt$<salt>$<derived>"
ADMIN_SESSION_SECRET="replace-with-a-long-random-secret"

# Supabase (admin dashboard reads/writes via SSR)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SERVICE_ROLE_KEY="<service-role-key>"

# Optional Supabase Storage S3-compatible endpoint used by release tooling.
SUPABASE_PROJECT_REF="<project-ref>"
SUPABASE_STORAGE_S3_ENDPOINT="https://<project-ref>.storage.supabase.co/storage/v1/s3"
SUPABASE_STORAGE_S3_ACCESS_KEY_ID="<storage-access-key-id>"
SUPABASE_STORAGE_S3_SECRET_ACCESS_KEY="<storage-secret-access-key>"

# SMTP (Gmail) — used by the admin to reply to users by email.
# For Gmail use an App Password (no spaces): https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="you@gmail.com"
SMTP_PASS=""
SMTP_FROM_NAME="Moalfarras.space"
SMTP_FROM_EMAIL="you@gmail.com"
CONTACT_TO_EMAIL="you@gmail.com"

# AI assistant / automation secrets are server-only and should mirror the web app
# project when the admin needs health checks or operation controls.
REQUEST_GUARD_SECRET="<long-random-request-guard-secret>"
ASSISTANT_OTP_SECRET="<long-random-assistant-otp-hmac-secret>"
AUTOMATION_API_KEY="<long-random-shared-secret>"
CMS_REVALIDATE_SECRET="<same-long-random-secret-in-web-and-admin>"
N8N_WEBHOOK_URL="<n8n-webhook-url>"
N8N_WEBHOOK_SECRET="<long-random-n8n-callback-secret>"

# Cross-app links
NEXT_PUBLIC_WEB_APP_URL="https://moalfarras.space"
NEXT_PUBLIC_ADMIN_APP_URL="https://admin.moalfarras.space"
# Default locale segment for Website Control deep links (en or ar)
NEXT_PUBLIC_WEB_ADMIN_DEFAULT_LOCALE="en"
