<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Premium Input Field Selector.
    - Default: Translucent dark
    - Focused: Brighter background + White Border + Scale effect (handled in code/animator)
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#2EFFFFFF" />
            <stroke android:width="2dp" android:color="@color/cinematic_focus_soft" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="10dp" />
            <solid android:color="#18FFFFFF" />
            <stroke android:width="1dp" android:color="@color/cinematic_divider" />
        </shape>
    </item>
</selector>
