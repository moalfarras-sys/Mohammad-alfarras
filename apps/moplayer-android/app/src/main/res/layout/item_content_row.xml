<?xml version="1.0" encoding="utf-8"?>
<!-- Content Row with fixed height to prevent focus overlap -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingTop="6dp"
    android:paddingBottom="12dp">

    <!-- Row Title -->
    <TextView
        android:id="@+id/tvRowTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/screen_margin_horizontal"
        android:layout_marginBottom="14dp"
        android:textColor="@color/cinematic_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.01"
        android:alpha="0.94"
        tools:text="New Movies" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvRowItems"
        android:layout_width="match_parent"
        android:layout_height="@dimen/content_row_items_height"
        android:clipToPadding="false"
        android:clipChildren="false"
        android:paddingStart="@dimen/screen_margin_horizontal"
        android:paddingEnd="@dimen/screen_margin_horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="10dp"
        android:orientation="horizontal"
        tools:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_content_card" />

</LinearLayout>
