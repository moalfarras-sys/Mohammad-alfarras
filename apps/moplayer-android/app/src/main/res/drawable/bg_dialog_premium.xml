<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#1500FF88" />
        </shape>
    </item>
    <!-- Main background -->
    <item
        android:bottom="2dp"
        android:left="1dp"
        android:right="1dp"
        android:top="1dp">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="135"
                android:centerColor="#F00A0A0F"
                android:endColor="#F0080810"
                android:startColor="#F00D0D14"
                android:type="linear" />
            <stroke
                android:width="1dp"
                android:color="#2500FF88" />
        </shape>
    </item>
</layer-list>
