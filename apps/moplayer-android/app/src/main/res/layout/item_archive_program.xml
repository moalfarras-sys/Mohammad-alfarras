<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/programContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="@dimen/liquid_space_8"
    android:layout_marginBottom="@dimen/liquid_space_8"
    android:background="@drawable/bg_liquid_glass_card"
    android:focusable="true"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/liquid_space_16">

    <!-- Time Badge -->
    <LinearLayout
        android:layout_width="92dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvStartTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/liquid_accent_primary"
            android:textSize="@dimen/liquid_text_body"
            android:textStyle="bold"
            tools:text="14:00" />

        <TextView
            android:id="@+id/tvEndTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/liquid_text_tertiary"
            android:textSize="@dimen/liquid_text_caption"
            tools:text="- 15:00" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="48dp"
        android:layout_marginHorizontal="@dimen/liquid_space_16"
        android:background="@color/liquid_divider" />

    <!-- Program Info -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvProgramTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/liquid_text_primary"
            android:textSize="@dimen/liquid_text_body"
            android:textStyle="bold"
            tools:text="Movie Title" />

        <TextView
            android:id="@+id/tvProgramDescription"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/liquid_space_4"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/liquid_text_secondary"
            android:textSize="@dimen/liquid_text_caption"
            tools:text="Program description goes here..." />

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/liquid_space_4"
            android:textColor="@color/liquid_text_tertiary"
            android:textSize="@dimen/liquid_text_caption"
            tools:text="60 min" />

    </LinearLayout>

    <!-- Play Button Indicator -->
    <ImageView
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="@dimen/liquid_space_16"
        android:src="@drawable/ic_play"
        app:tint="@color/liquid_accent_primary"
        tools:ignore="ContentDescription" />

</LinearLayout>
