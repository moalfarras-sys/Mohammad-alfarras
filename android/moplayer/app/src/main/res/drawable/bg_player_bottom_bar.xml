<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <!-- Glass background -->
            <solid android:color="#7A060A14" />
            <!-- Rounded corners -->
            <corners android:radius="24dp" />
            <!-- Glass border -->
            <stroke android:width="1dp" android:color="#3300F5FF" />
        </shape>
    </item>
    <!-- Inner subtle glow/highlight at the top to simulate thickness -->
    <item android:top="1dp" android:left="1dp" android:right="1dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="23dp" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</layer-list>
