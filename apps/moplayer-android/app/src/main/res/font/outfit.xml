<?xml version="1.0" encoding="utf-8"?>
<!-- Outfit — geometric brand/heading family. Weight-mapped so textStyle="bold" picks the real bold cut. -->
<font-family xmlns:app="http://schemas.android.com/apk/res-auto">
    <font app:fontStyle="normal" app:fontWeight="400" app:font="@font/outfit_regular" />
    <font app:fontStyle="normal" app:fontWeight="500" app:font="@font/outfit_medium" />
    <font app:fontStyle="normal" app:fontWeight="700" app:font="@font/outfit_bold" />
    <font app:fontStyle="normal" app:fontWeight="800" app:font="@font/outfit_extrabold" />
</font-family>
