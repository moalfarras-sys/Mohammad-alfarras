<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50dp"
                android:startColor="@color/htc_accent_green"
                android:endColor="@color/htc_accent_green_dark" />
            <stroke
                android:width="2dp"
                android:color="@color/htc_accent_green_light" />
        </shape>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50dp"
                android:startColor="@color/htc_accent_green_dark"
                android:endColor="@color/htc_accent_green" />
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="50dp"
                android:startColor="@color/htc_medium_gray"
                android:endColor="@color/htc_dark_gray" />
            <stroke
                android:width="2dp"
                android:color="@color/htc_glass_border" />
        </shape>
    </item>

</selector>
