<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-8dp"
                android:top="-8dp"
                android:right="-8dp"
                android:bottom="-8dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="150dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="@color/liquid_focus_glow"
                        android:centerColor="@color/liquid_accent_primary_soft"
                        android:endColor="#00000000" />
                </shape>
            </item>
            
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <gradient
                        android:angle="315"
                        android:startColor="#2CFFFFFF"
                        android:centerColor="@color/cinematic_violet_subtle"
                        android:endColor="#1822D3EE" />
                </shape>
            </item>
            
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <stroke
                        android:width="@dimen/focus_border_width"
                        android:color="@color/liquid_focus_ring" />
                </shape>
            </item>
            
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/liquid_glass_highlight" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_selected="true">
        <layer-list>
            <item
                android:left="-4dp"
                android:top="-4dp"
                android:right="-4dp"
                android:bottom="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="80dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="@color/liquid_accent_primary_soft"
                        android:endColor="#00000000" />
                </shape>
            </item>
            
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/card_corner_radius" />
                <gradient
                    android:angle="315"
                    android:startColor="@color/liquid_glass_surface"
                    android:endColor="@color/liquid_glass_surface_strong" />
                <stroke
                    android:width="2dp"
                    android:color="@color/liquid_glass_border" />
            </shape>
        </layer-list>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/card_corner_radius" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</selector>
