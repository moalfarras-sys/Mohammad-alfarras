<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Focused State -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/htc_dark_gray"/>
            <stroke
                android:width="2dp"
                android:color="@color/htc_accent_gold"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
    
    <!-- Default State -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/htc_medium_gray"/>
            <stroke
                android:width="1dp"
                android:color="@color/htc_text_secondary"/>
            <corners android:radius="8dp"/>
        </shape>
    </item>
</selector>
