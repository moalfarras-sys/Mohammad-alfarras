<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    android:opacity="opaque">

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="@color/cinematic_bg_base"
                android:centerColor="@color/cinematic_bg_elevated"
                android:endColor="@color/cinematic_bg_base" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="400"
                android:startColor="@color/cinematic_violet_subtle"
                android:endColor="#00080A0D" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:centerX="0.35"
                android:centerY="0.35"
                android:gradientRadius="320"
                android:startColor="@color/cinematic_blue_glow_subtle"
                android:endColor="#00000000" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:width="260dp"
        android:height="260dp"
        android:drawable="@drawable/moplayer_logo_transparent_v1_full" />

</layer-list>
