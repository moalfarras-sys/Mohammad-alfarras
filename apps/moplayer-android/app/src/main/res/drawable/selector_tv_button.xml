<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused and pressed -->
    <item android:state_focused="true" android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/moplayer_orange_dark" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Focused -->
    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-2dp"
                android:top="-2dp"
                android:right="-2dp"
                android:bottom="-2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="14dp" />
                    <gradient
                        android:type="radial"
                    android:gradientRadius="132dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#AA5B7CFF"
                        android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:angle="135"
                        android:startColor="#8846F6FF"
                        android:centerColor="#663B82F6"
                        android:endColor="#887C3AED" />
                    <corners android:radius="12dp" />
                    <stroke
                        android:width="2.5dp"
                        android:color="#FFFFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/liquid_glass_surface_strong" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <!-- Normal - Glass surface -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="#40173968"
                android:centerColor="#2D102044"
                android:endColor="#35160630" />
            <stroke
                android:width="1.2dp"
                android:color="#4AB9F7FF" />
            <corners android:radius="12dp" />
        </shape>
    </item>

</selector>
