<?xml version="1.0" encoding="utf-8"?>
<!-- Luxury Weather Widget with Gold Accents and Extended Info -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="@drawable/bg_weather_card">

    <!-- Weather Icon with Luxury Shadow -->
    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp">

        <!-- Gold Glow Behind Icon -->
        <View
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_icon_glow"
            android:alpha="0.4" />

        <!-- Shadow for 3D effect -->
        <ImageView
            android:id="@+id/ivWeatherIconShadow"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="4dp"
            android:layout_marginTop="4dp"
            android:alpha="0.25"
            android:src="@drawable/ic_weather_sunny"
            app:tint="#000000"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/ivWeatherIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_weather_sunny"
            app:tint="@color/gradient_gold_start"
            tools:ignore="ContentDescription" />

    </FrameLayout>

    <!-- Temperature and City with Premium Typography -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTemperature"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:textColor="@color/htc_text_primary"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:shadowColor="@color/glow_gold_subtle"
            android:shadowDx="0"
            android:shadowDy="0"
            android:shadowRadius="8"
            tools:text="22°" />

        <TextView
            android:id="@+id/tvCity"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxWidth="120dp"
            android:maxLines="1"
            android:textColor="@color/gradient_gold_mid"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            tools:text="New York"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/tvCondition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/htc_text_tertiary"
            android:textSize="11sp"
            android:visibility="gone"
            tools:text="Sunny"
            tools:visibility="visible" />

    </LinearLayout>

    <!-- Divider -->
    <View
        android:id="@+id/weatherDivider"
        android:layout_width="1dp"
        android:layout_height="40dp"
        android:layout_marginHorizontal="12dp"
        android:background="@color/card_border_luxury_subtle"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Extended Weather Info (humidity, wind) -->
    <LinearLayout
        android:id="@+id/extendedWeatherInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Humidity -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_humidity"
                app:tint="@color/gradient_gold_mid"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvHumidity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="11sp"
                tools:text="65%" />

        </LinearLayout>

        <!-- Wind Speed -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_wind"
                app:tint="@color/gradient_gold_mid"
                tools:ignore="ContentDescription" />

            <TextView
                android:id="@+id/tvWindSpeed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="11sp"
                tools:text="12 km/h" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>

