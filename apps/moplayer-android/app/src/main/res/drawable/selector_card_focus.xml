<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-5dp"
                android:top="-5dp"
                android:right="-5dp"
                android:bottom="-5dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="150dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="#6600E5FF"
                        android:centerColor="@color/moplayer_orange_subtle"
                        android:endColor="#00000000" />
                </shape>
            </item>
            
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <gradient
                        android:angle="315"
                        android:startColor="#D20A2A3E"
                        android:centerColor="#D20A1E34"
                        android:endColor="#D2081226" />
                </shape>
            </item>
            
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <stroke
                        android:width="3dp"
                        android:color="#D900E5FF" />
                </shape>
            </item>
            
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <stroke
                        android:width="1dp"
                        android:color="#405DEBFF" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item android:state_selected="true">
        <layer-list>
            <item
                android:left="-4dp"
                android:top="-4dp"
                android:right="-4dp"
                android:bottom="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="@dimen/card_corner_radius" />
                    <gradient
                        android:type="radial"
                        android:gradientRadius="80dp"
                        android:centerX="0.5"
                        android:centerY="0.5"
                        android:startColor="@color/liquid_accent_primary_soft"
                        android:endColor="#00000000" />
                </shape>
            </item>
            
            <shape android:shape="rectangle">
                <corners android:radius="@dimen/card_corner_radius" />
                <gradient
                    android:angle="315"
                    android:startColor="@color/liquid_glass_surface"
                    android:endColor="@color/liquid_glass_surface_strong" />
                <stroke
                    android:width="2dp"
                    android:color="@color/liquid_glass_border" />
            </shape>
        </layer-list>
    </item>

    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/card_corner_radius" />
            <solid android:color="#00000000" />
        </shape>
    </item>

</selector>
