<?xml version="1.0" encoding="utf-8"?>
<!-- Shadcn-style High Visibility Focus Selector -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <layer-list>
            <item android:left="-4dp" android:top="-4dp" android:right="-4dp" android:bottom="-4dp">
                <shape android:shape="rectangle">
                    <corners android:radius="16dp" />
                    <stroke android:width="2dp" android:color="@color/moplayer_orange_glow" />
                </shape>
            </item>

            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="12dp" />
                    <solid android:color="@color/zinc_800" />
                    <stroke android:width="3dp" android:color="@color/moplayer_orange" />
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- PRESSED STATE: Darker Background -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/zinc_700" />
            <stroke android:width="1dp" android:color="@color/zinc_400" />
        </shape>
    </item>

    <!-- DEFAULT STATE: Transparent (Icon-only buttons) or Subtle Border -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

</selector>
