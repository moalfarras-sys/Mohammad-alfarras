<?xml version="1.0" encoding="utf-8"?>
<!-- Full-Screen Weather Overlay
     
     A transparent overlay that displays weather effects across the entire screen.
     - Non-interactive (won't block touch events)
     - Covers full screen behind content
     - Hardware accelerated for smooth animations
-->
<com.mo.moplayer.ui.widgets.weather.FullScreenWeatherOverlay
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/weatherOverlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="false"
    android:focusable="false"
    android:importantForAccessibility="no" />
