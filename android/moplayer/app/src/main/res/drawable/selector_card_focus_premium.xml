<?xml version="1.0" encoding="utf-8"?>
<!-- Card Focus selector with premium gold glow effect -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state with gold glow -->
    <item android:state_focused="true">
        <layer-list>
            <!-- Outer glow -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/glow_gold_subtle" />
                    <corners android:radius="16dp" />
                </shape>
            </item>
            <!-- Main card background -->
            <item android:bottom="2dp" android:left="2dp" android:right="2dp" android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@color/card_bg_luxury_elevated" />
                    <corners android:radius="14dp" />
                    <stroke android:width="2dp" android:color="@color/htc_accent_gold" />
                </shape>
            </item>
        </layer-list>
    </item>
    
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/card_bg_luxury_elevated" />
            <corners android:radius="14dp" />
            <stroke android:width="2dp" android:color="@color/gradient_gold_mid" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_bg_luxury" />
            <corners android:radius="14dp" />
            <stroke android:width="1dp" android:color="@color/htc_card_border" />
        </shape>
    </item>
    
</selector>
