<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:endColor="@color/cinematic_violet"
                android:startColor="@color/liquid_accent_primary_pressed" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:endColor="@color/cinematic_violet_light"
                android:startColor="@color/liquid_accent_primary" />
            <stroke
                android:width="2.5dp"
                android:color="@color/login_white" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:endColor="@color/cinematic_violet"
                android:startColor="@color/liquid_accent_primary" />
            <stroke
                android:width="1dp"
                android:color="@color/cinematic_glass_highlight" />
        </shape>
    </item>

</selector>
