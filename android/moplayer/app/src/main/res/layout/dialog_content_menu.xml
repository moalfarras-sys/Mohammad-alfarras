<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#DD000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="560dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_dialog_premium"
            android:orientation="vertical"
            android:paddingHorizontal="28dp"
            android:paddingTop="24dp"
            android:paddingBottom="20dp"
            android:elevation="16dp">

            <!-- Header with Title and Thumbnail -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <!-- Thumbnail with rounded corners -->
                <androidx.cardview.widget.CardView
                    android:layout_width="100dp"
                    android:layout_height="140dp"
                    android:layout_marginEnd="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/htc_dark_gray">

                    <ImageView
                        android:id="@+id/ivThumbnail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/moplayer_logo_placeholder"
                        tools:ignore="ContentDescription" />

                </androidx.cardview.widget.CardView>

                <!-- Title and metadata -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvContentTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/htc_text_primary"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        tools:text="The Dark Knight" />

                    <!-- Metadata row: Rating | Duration | Year | Genre -->
                    <LinearLayout
                        android:id="@+id/layoutMetadata"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvRating"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_rating_badge"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/htc_accent_gold"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="8.5"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/tvDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/htc_text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="2h 32min"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/tvYear"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/htc_text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="2008"
                            tools:visibility="visible" />

                        <TextView
                            android:id="@+id/tvGenre"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/htc_text_secondary"
                            android:textSize="13sp"
                            android:visibility="gone"
                            tools:text="Action, Drama"
                            tools:visibility="visible" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Description / Plot -->
            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:maxLines="4"
                android:ellipsize="end"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/htc_text_secondary"
                android:textSize="14sp"
                android:visibility="gone"
                tools:text="When the menace known as the Joker wreaks havoc and chaos on the people of Gotham, Batman must accept one of the greatest psychological and physical tests of his ability to fight injustice."
                tools:visibility="visible" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/htc_card_border"
                android:alpha="0.5"
                android:layout_marginBottom="12dp" />

            <!-- Menu Items RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMenuItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:overScrollMode="never"
                tools:itemCount="5"
                tools:listitem="@layout/item_context_menu" />

        </LinearLayout>

    </ScrollView>

</FrameLayout>
