<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#4A101B36" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#5A132346" />
            <stroke
                android:width="2.5dp"
                android:color="@color/liquid_focus_ring" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#36111C36" />
            <stroke
                android:width="1dp"
                android:color="@color/cinematic_glass_border" />
        </shape>
    </item>

</selector>
