<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow (blue-violet) -->
    <item
        android:left="-4dp"
        android:top="-4dp"
        android:right="-4dp"
        android:bottom="-4dp">
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:type="radial"
                android:gradientRadius="250dp"
                android:centerX="0.5"
                android:centerY="0.3"
                android:startColor="#164F8BFF"
                android:centerColor="#0C8B5CF6"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Main glass surface -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:type="linear"
                android:angle="155"
                android:startColor="#E00D1220"
                android:centerColor="#D80B1018"
                android:endColor="#D00B0F1A" />
            <stroke
                android:width="1dp"
                android:color="#1CFFFFFF" />
        </shape>
    </item>
    <!-- Top highlight (accent hint) -->
    <item android:top="1dp" android:left="20dp" android:right="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#224F8BFF"
                android:endColor="#00FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>
    <!-- Inner reflection -->
    <item android:top="2dp" android:left="3dp" android:right="3dp">
        <shape android:shape="rectangle">
            <corners android:topLeftRadius="18dp" android:topRightRadius="18dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#0AFFFFFF"
                android:endColor="#00FFFFFF" />
            <size android:height="24dp" />
        </shape>
    </item>
</layer-list>
