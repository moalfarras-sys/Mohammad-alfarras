<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer glow (violet-blue) -->
    <item
        android:left="-3dp"
        android:top="-3dp"
        android:right="-3dp"
        android:bottom="-3dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/dock_corner_radius" />
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#144F8BFF"
                android:centerColor="#088B5CF6"
                android:endColor="#00000000" />
        </shape>
    </item>
    <!-- Main glass surface — ultra-deep -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/dock_corner_radius" />
            <gradient
                android:angle="90"
                android:startColor="#E00B0F1A"
                android:centerColor="#D50D1220"
                android:endColor="#C80F1528" />
            <stroke android:width="1dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
    <!-- Top highlight shimmer -->
    <item android:top="1dp" android:left="32dp" android:right="32dp">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#18FFFFFF"
                android:endColor="#00FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>
    <!-- Inner glass reflection -->
    <item android:top="2dp" android:left="12dp" android:right="12dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/dock_corner_radius" />
            <gradient
                android:angle="270"
                android:startColor="#06FFFFFF"
                android:endColor="#00000000" />
            <size android:height="20dp" />
        </shape>
    </item>
</layer-list>
