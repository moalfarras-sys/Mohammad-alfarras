{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": null,
  "installCommand": "",
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/admin",
      "destination": "https://app-next-blond.vercel.app/ar/admin",
      "permanent": false
    },
    {
      "source": "/ar/admin",
      "destination": "https://app-next-blond.vercel.app/ar/admin",
      "permanent": false
    },
    {
      "source": "/en/admin",
      "destination": "https://app-next-blond.vercel.app/en/admin",
      "permanent": false
    },
    {
      "source": "/",
      "destination": "https://app-next-blond.vercel.app/ar",
      "permanent": false
    },
    {
      "source": "/ar",
      "destination": "https://app-next-blond.vercel.app/ar",
      "permanent": false
    },
    {
      "source": "/en",
      "destination": "https://app-next-blond.vercel.app/en",
      "permanent": false
    },
    {
      "source": "/ar/cv",
      "destination": "https://app-next-blond.vercel.app/ar/cv",
      "permanent": false
    },
    {
      "source": "/ar/blog",
      "destination": "https://app-next-blond.vercel.app/ar/blog",
      "permanent": false
    },
    {
      "source": "/ar/youtube",
      "destination": "https://app-next-blond.vercel.app/ar/youtube",
      "permanent": false
    },
    {
      "source": "/ar/contact",
      "destination": "https://app-next-blond.vercel.app/ar/contact",
      "permanent": false
    },
    {
      "source": "/ar/privacy",
      "destination": "https://app-next-blond.vercel.app/ar/privacy",
      "permanent": false
    },
    {
      "source": "/en/cv",
      "destination": "https://app-next-blond.vercel.app/en/cv",
      "permanent": false
    },
    {
      "source": "/en/blog",
      "destination": "https://app-next-blond.vercel.app/en/blog",
      "permanent": false
    },
    {
      "source": "/en/youtube",
      "destination": "https://app-next-blond.vercel.app/en/youtube",
      "permanent": false
    },
    {
      "source": "/en/contact",
      "destination": "https://app-next-blond.vercel.app/en/contact",
      "permanent": false
    },
    {
      "source": "/en/privacy",
      "destination": "https://app-next-blond.vercel.app/en/privacy",
      "permanent": false
    },
    {
      "source": "/cv",
      "destination": "https://app-next-blond.vercel.app/ar/cv",
      "permanent": false
    },
    {
      "source": "/blog",
      "destination": "https://app-next-blond.vercel.app/ar/blog",
      "permanent": false
    },
    {
      "source": "/youtube",
      "destination": "https://app-next-blond.vercel.app/ar/youtube",
      "permanent": false
    },
    {
      "source": "/contact",
      "destination": "https://app-next-blond.vercel.app/ar/contact",
      "permanent": false
    },
    {
      "source": "/privacy",
      "destination": "https://app-next-blond.vercel.app/ar/privacy",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/ar",
      "destination": "/index.html"
    },
    {
      "source": "/ar/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/ar/cv",
      "destination": "/cv.html"
    },
    {
      "source": "/ar/blog",
      "destination": "/blog.html"
    },
    {
      "source": "/ar/youtube",
      "destination": "/youtube.html"
    },
    {
      "source": "/ar/contact",
      "destination": "/contact.html"
    },
    {
      "source": "/ar/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/en",
      "destination": "/en/index.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/en/admin",
      "destination": "/en/admin.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    }
  ]
}
