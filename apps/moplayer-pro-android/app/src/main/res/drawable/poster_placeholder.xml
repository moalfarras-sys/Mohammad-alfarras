<?xml version="1.0" encoding="utf-8"?>
<!-- Subtle dark poster placeholder (loading / missing art). A plain VectorDrawable so
     painterResource can load it (layer-list/shape drawables are NOT supported there).
     Cleaner in a grid than flashing the full app logo, with a faint on-brand play glyph. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="180dp"
    android:viewportWidth="120"
    android:viewportHeight="180">
    <!-- dark base fills the whole cell (the card clips the corners) -->
    <path
        android:fillColor="#FF141009"
        android:pathData="M0,0h120v180H0z" />
    <!-- faint ring -->
    <path
        android:strokeColor="#26E3BC78"
        android:strokeWidth="1.3"
        android:pathData="M60,90m-18,0a18,18 0,1,1 36,0a18,18 0,1,1 -36,0" />
    <!-- faint play glyph -->
    <path
        android:fillColor="#4DE3BC78"
        android:pathData="M55,82 L55,98 L69,90 Z" />
</vector>
