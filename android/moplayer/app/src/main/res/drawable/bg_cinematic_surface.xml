<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/cinematic_radius_surface" />
            <gradient
                android:angle="155"
                android:startColor="@color/cinematic_surface"
                android:centerColor="@color/cinematic_bg_elevated"
                android:endColor="@color/cinematic_bg_base" />
            <stroke android:width="1dp" android:color="#14FFFFFF" />
        </shape>
    </item>
    <!-- Top highlight -->
    <item android:top="1dp" android:left="20dp" android:right="20dp">
        <shape android:shape="rectangle">
            <corners android:radius="1dp" />
            <gradient
                android:type="linear"
                android:angle="0"
                android:startColor="#00FFFFFF"
                android:centerColor="#0CFFFFFF"
                android:endColor="#00FFFFFF" />
            <size android:height="1dp" />
        </shape>
    </item>
    <!-- Inner reflection -->
    <item android:top="2dp" android:left="8dp" android:right="8dp">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/cinematic_radius_surface" />
            <gradient
                android:angle="270"
                android:startColor="#04FFFFFF"
                android:endColor="#00000000" />
            <size android:height="20dp" />
        </shape>
    </item>
</layer-list>
