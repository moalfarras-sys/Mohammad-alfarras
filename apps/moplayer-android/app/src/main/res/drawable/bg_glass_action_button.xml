<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Action Button - Blue Gradient -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/htc_button_focused_start"
                android:endColor="@color/htc_button_focused_end" />
        </shape>
    </item>
    
    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/htc_accent_green_dark" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="@color/htc_accent_green"
                android:endColor="@color/htc_accent_green_dark" />
        </shape>
    </item>
    
</selector>
