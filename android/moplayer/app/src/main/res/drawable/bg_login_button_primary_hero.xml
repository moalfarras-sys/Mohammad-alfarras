<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:endColor="#5E7BFF"
                android:startColor="#355DCC" />
        </shape>
    </item>

    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:endColor="#88B8FF"
                android:startColor="#4F8BFF" />
            <stroke
                android:width="2dp"
                android:color="#BFFFFFFF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:endColor="#7BA4FF"
                android:startColor="#4679F4" />
            <stroke
                android:width="1dp"
                android:color="#4DFFFFFF" />
        </shape>
    </item>

</selector>
