<?xml version="1.0" encoding="utf-8"?>
<!-- Play/Pause button — large premium circle -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <layer-list>
            <item android:left="-6dp" android:top="-6dp" android:right="-6dp" android:bottom="-6dp">
                <shape android:shape="oval">
                    <gradient android:type="radial" android:gradientRadius="80dp"
                        android:centerX="0.5" android:centerY="0.5"
                        android:startColor="#8800F5FF" android:endColor="#00000000" />
                </shape>
            </item>
            <item>
                <shape android:shape="oval">
                    <gradient android:type="radial" android:gradientRadius="60dp"
                        android:centerX="0.5" android:centerY="0.5"
                        android:startColor="#445B7CFF" android:endColor="#185B7CFF" />
                    <stroke android:width="2dp" android:color="#CC5B7CFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="#225B7CFF" />
            <stroke android:width="2dp" android:color="#8000F5FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient android:type="radial" android:gradientRadius="60dp"
                android:centerX="0.5" android:centerY="0.5"
                android:startColor="#285B7CFF" android:endColor="#0E00F5FF" />
            <stroke android:width="1.5dp" android:color="#605B7CFF" />
        </shape>
    </item>
</selector>
