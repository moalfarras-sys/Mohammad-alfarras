<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true" android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <gradient
                        android:angle="0"
                        android:startColor="#5B7CFF"
                        android:endColor="#00E5FF" />
                    <stroke android:width="2dp" android:color="#E572E7F2" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <gradient
                android:angle="0"
                android:startColor="#5B7CFF"
                android:endColor="#00E5FF" />
        </shape>
    </item>
    <item android:state_focused="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <corners android:radius="20dp" />
                    <gradient
                        android:angle="135"
                        android:startColor="#C20A3E54"
                        android:endColor="#C214294D" />
                    <stroke
                        android:width="2dp"
                        android:color="#FF72E7F2" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="20dp" />
            <solid android:color="#22173568" />
            <stroke android:width="1dp" android:color="#44B9F7FF" />
        </shape>
    </item>
</selector>
