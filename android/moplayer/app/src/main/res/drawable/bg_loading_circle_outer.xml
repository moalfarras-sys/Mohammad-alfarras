<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="sweep"
                android:startColor="@color/moplayer_orange"
                android:centerColor="@color/moplayer_orange_light"
                android:endColor="@color/moplayer_orange" />
            <size
                android:width="260dp"
                android:height="260dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="@color/moplayer_orange" />
            <size
                android:width="260dp"
                android:height="260dp" />
        </shape>
    </item>
</layer-list>
