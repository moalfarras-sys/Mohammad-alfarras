<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/liquid_bg_base">

    <!-- VLC Player Surface (Full Screen Background) -->
    <org.videolan.libvlc.util.VLCVideoLayout
        android:id="@+id/vlcVideoLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Dark Overlay (80% black when overlay visible) -->
        <View
            android:id="@+id/darkOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/liquid_overlay_scrim"
            android:visibility="gone" />

    <!-- ======================= -->
    <!-- TiviMate Style Overlay  -->
    <!-- ======================= -->
    <LinearLayout
        android:id="@+id/fullScreenOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- ================= -->
        <!-- LEFT PANEL - 22%  -->
        <!-- Groups List       -->
        <!-- ================= -->
        <LinearLayout
            android:id="@+id/leftPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="28"
            android:layout_marginStart="14dp"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_panel_floating_glass"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- Groups Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="14dp"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:tag="accent_icon"
                    android:src="@drawable/ic_live_tv"
                    app:tint="@color/liquid_accent_primary"
                    tools:ignore="ContentDescription" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:tag="accent_text"
                    android:text="@string/live_tv_categories"
                    android:textColor="@color/liquid_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="12dp"
                android:background="@color/color_glass_20" />

            <!-- Groups RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvGroups"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:descendantFocusability="afterDescendants"
                android:nextFocusRight="@id/rvChannels"
                android:nextFocusLeft="@id/rvGroups"
                android:nextFocusUp="@id/rvGroups"
                android:nextFocusDown="@id/rvGroups"
                android:paddingVertical="8dp"
                android:paddingHorizontal="6dp"
                tools:listitem="@layout/item_group_tivimate" />

        </LinearLayout>

        <!-- Vertical Divider -->
        <View
            android:layout_width="12dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <!-- ================== -->
        <!-- CENTER PANEL - 48% -->
        <!-- Channels List      -->
        <!-- ================== -->
        <LinearLayout
            android:id="@+id/centerPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="54"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_panel_floating_glass"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <!-- Channels Header with Search + Count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp">

                <!-- Accent Bar -->
                <View
                    android:layout_width="3dp"
                    android:layout_height="28dp"
                    android:background="@color/liquid_accent_primary" />

                <!-- Category Name -->
                <TextView
                    android:id="@+id/tvCurrentCategory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:tag="accent_text"
                    android:text="@string/all_categories"
                    android:textColor="@color/liquid_text_primary"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <!-- Channel Count Badge -->
                <TextView
                    android:id="@+id/tvChannelCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:tag="accent_text"
                    android:background="@drawable/bg_count_badge"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="5dp"
                    android:textColor="@color/liquid_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="245 channels" />

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="14dp"
                android:background="@color/color_glass_15" />

            <!-- Channels RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvChannels"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:descendantFocusability="afterDescendants"
                android:nextFocusLeft="@id/rvGroups"
                android:nextFocusRight="@id/rvChannels"
                android:nextFocusUp="@id/rvChannels"
                android:nextFocusDown="@id/rvChannels"
                android:paddingVertical="8dp"
                android:paddingHorizontal="8dp"
                tools:listitem="@layout/item_channel_tivimate" />

        </LinearLayout>

        <!-- Vertical Divider -->
        <View
            android:layout_width="12dp"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <!-- ================= -->
        <!-- RIGHT PANEL - 30% -->
        <!-- Preview + Info    -->
        <!-- ================= -->
        <LinearLayout
            android:id="@+id/previewPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="18"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/bg_panel_floating_glass"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Mini Video Preview Container -->
            <FrameLayout
                android:id="@+id/miniPreviewContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <!-- Preview Glow Background -->
                <View
                    android:id="@+id/previewGlow"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_margin="-8dp"
                    android:alpha="0.25"
                    android:background="@drawable/bg_preview_glow" />

                <!-- Video Preview Surface -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@color/color_black"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="8dp">

                    <org.videolan.libvlc.util.VLCVideoLayout
                        android:id="@+id/miniPreviewVlcLayout"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <!-- Preview Loading -->
                    <ProgressBar
                        android:id="@+id/previewLoading"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/liquid_accent_primary"
                        android:visibility="gone" />

                    <!-- No Preview Placeholder -->
                    <LinearLayout
                        android:id="@+id/noPreviewPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/color_surface_dark"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <ImageView
                            android:id="@+id/ivPreviewLogo"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_placeholder_channel"
                            tools:ignore="ContentDescription" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="@string/preview"
                            android:textColor="@color/liquid_text_tertiary"
                            android:textSize="12sp" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <!-- "LIVE" Badge -->
                <TextView
                    android:id="@+id/tvLiveBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|end"
                    android:layout_margin="16dp"
                    android:tag="accent_text"
                    android:background="@drawable/bg_type_badge_live"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:text="LIVE"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- Channel Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/color_glass_15"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Channel Logo + Name Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Channel Logo -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="60dp"
                            android:layout_height="45dp"
                            app:cardBackgroundColor="@color/color_glass_20"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp">

                            <ImageView
                                android:id="@+id/ivChannelLogo"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:padding="6dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_placeholder_channel"
                                tools:ignore="ContentDescription" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <!-- Channel Number Badge -->
                            <TextView
                                android:id="@+id/tvChannelNumber"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:tag="accent_text"
                                android:background="@drawable/bg_channel_number_badge"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="3dp"
                                android:textColor="@color/liquid_bg_base"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                tools:text="125" />

                            <!-- Channel Name -->
                            <TextView
                                android:id="@+id/tvChannelName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:tag="accent_text"
                                android:textColor="@color/liquid_text_primary"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                tools:text="Discovery Channel HD" />

                        </LinearLayout>

                        <!-- Quality Badge -->
                        <TextView
                            android:id="@+id/tvQuality"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_quality_badge_premium"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:textColor="@color/liquid_bg_base"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="gone"
                            tools:text="4K"
                            tools:visibility="visible" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- EPG Info Card - Current Program -->
            <androidx.cardview.widget.CardView
                android:id="@+id/epgCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/color_glass_10"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Now Playing Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_now_playing_dot" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/now_playing"
                            android:textColor="@color/liquid_accent_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNowTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textColor="@color/liquid_text_tertiary"
                            android:textSize="11sp"
                            tools:text="14:30 - 15:00" />
                    </LinearLayout>

                    <!-- Current Program Title -->
                    <TextView
                        android:id="@+id/tvNowPlaying"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:textColor="@color/liquid_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="Shark Week: Great White Encounter" />

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/epgProgressBar"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="10dp"
                        android:max="100"
                        android:progress="35"
                        android:progressDrawable="@drawable/bg_progress_bar"
                        android:visibility="gone"
                        tools:visibility="visible" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="@color/color_glass_10" />

                    <!-- Next Program Header -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/next_program"
                        android:textColor="@color/liquid_text_tertiary"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <!-- Next Program -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tvNextTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/liquid_text_tertiary"
                            android:textSize="12sp"
                            tools:text="15:00" />

                        <TextView
                            android:id="@+id/tvNextProgram"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:layout_weight="1"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/liquid_text_secondary"
                            android:textSize="13sp"
                            tools:text="Documentary: Ocean Mysteries" />
                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Clock Display -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:tag="accent_text"
                    android:textColor="@color/liquid_accent_primary"
                    android:textSize="42sp"
                    android:textStyle="bold"
                    tools:text="14:35" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- ======================= -->
    <!-- Channel Info Bar (Top)  -->
    <!-- Shows when overlay off  -->
    <!-- ======================= -->
    <LinearLayout
        android:id="@+id/channelInfoBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:background="@drawable/bg_live_info_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="32dp"
        android:paddingVertical="20dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Channel Logo with glow -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">

            <View
                android:layout_width="100dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:alpha="0.5"
                android:background="@drawable/bg_channel_logo_glow" />

            <androidx.cardview.widget.CardView
                android:layout_width="90dp"
                android:layout_height="70dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/color_glass_15"
                app:cardCornerRadius="10dp"
                app:cardElevation="4dp">

                <ImageView
                    android:id="@+id/ivInfoBarLogo"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_placeholder_channel"
                    tools:ignore="ContentDescription" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Channel Number + Name -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Channel Number Badge -->
                <TextView
                    android:id="@+id/tvInfoBarNumber"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_channel_number_badge"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:textColor="@color/liquid_bg_base"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    tools:text="125" />

                <TextView
                    android:id="@+id/tvInfoBarName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:ellipsize="end"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:textColor="@color/liquid_text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="Discovery Channel" />

                <!-- Quality Badge -->
                <TextView
                    android:id="@+id/tvInfoBarQuality"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_quality_badge_premium"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textColor="@color/liquid_bg_base"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:text="4K"
                    tools:visibility="visible" />
            </LinearLayout>

            <!-- Now Playing (EPG) -->
            <TextView
                android:id="@+id/tvInfoBarNowPlaying"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:drawablePadding="8dp"
                android:drawableStart="@drawable/bg_now_playing_dot"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/liquid_text_secondary"
                android:textSize="16sp"
                tools:text="Shark Week: Great White Encounter" />

        </LinearLayout>

        <!-- Clock Display -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

                <TextView
                    android:id="@+id/tvInfoBarClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-light"
                    android:tag="accent_text"
                    android:textColor="@color/liquid_accent_primary"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    tools:text="14:35" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE"
                android:textColor="@color/htc_error"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Quick Channel Number Input -->
    <FrameLayout
        android:id="@+id/channelInputContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone">

        <View
            android:layout_width="200dp"
            android:layout_height="120dp"
            android:alpha="0.6"
            android:background="@drawable/bg_channel_input_glow" />

        <TextView
            android:id="@+id/tvChannelInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="@drawable/bg_liquid_glass_surface"
            android:fontFamily="sans-serif-black"
            android:paddingHorizontal="48dp"
            android:paddingVertical="24dp"
            android:tag="accent_text"
            android:textColor="@color/liquid_accent_primary"
            android:textSize="64sp"
            android:textStyle="bold"
            tools:text="125" />
    </FrameLayout>

    <!-- Loading Indicator -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:indeterminateTint="@color/liquid_accent_primary" />

    </FrameLayout>

    <!-- Hint Text -->
    <TextView
        android:id="@+id/tvHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="32dp"
        android:background="@drawable/bg_hint_premium"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:tag="accent_text"
        android:text="@string/live_tv_press_ok"
        android:textColor="@color/liquid_text_secondary"
        android:textSize="14sp"
        android:visibility="gone" />

    <!-- Network Error Overlay with Retry -->
    <com.mo.moplayer.ui.common.LoadingStateView
        android:id="@+id/networkErrorView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

</FrameLayout>

