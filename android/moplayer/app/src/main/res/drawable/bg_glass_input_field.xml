<?xml version="1.0" encoding="utf-8"?>
<!-- Premium Input Field - Solid Minimal Design -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- Focused state - Blue accent border -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/htc_medium_gray" />
            <stroke
                android:width="2dp"
                android:color="@color/htc_accent_green" />
        </shape>
    </item>
    
    <!-- Default state -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="12dp" />
            <solid android:color="@color/htc_dark_gray" />
            <stroke
                android:width="1dp"
                android:color="@color/htc_silver" />
        </shape>
    </item>
    
</selector>
